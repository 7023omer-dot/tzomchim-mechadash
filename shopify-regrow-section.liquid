        <div class="addon">
          <div class="pimg" title="מברשת עיסוי קרקפת">
            <svg viewBox="0 0 220 220" role="img" aria-label="מברשת עיסוי קרקפת">
              <defs><linearGradient id="brRed" x1="0" y1="0" x2="1" y2="1"><stop offset="0" stop-color="#E64B3E"/><stop offset="1" stop-color="#9E1B1B"/></linearGradient></defs>
              <ellipse cx="110" cy="150" rx="44" ry="58" fill="url(#brRed)"/>
              <ellipse cx="110" cy="168" rx="15" ry="22" fill="#fff"/>
              <ellipse cx="110" cy="88" rx="76" ry="66" fill="url(#brRed)"/>
              <ellipse cx="110" cy="88" rx="60" ry="50" fill="#241f1d"/>
              <g fill="#E8584B">
                <circle cx="110" cy="62" r="5"/><circle cx="84" cy="74" r="5"/><circle cx="136" cy="74" r="5"/>
                <circle cx="72" cy="96" r="5"/><circle cx="98" cy="90" r="5"/><circle cx="122" cy="90" r="5"/><circle cx="148" cy="96" r="5"/>
                <circle cx="84" cy="114" r="5"/><circle cx="110" cy="110" r="5"/><circle cx="136" cy="114" r="5"/>
              </g>
            </svg>
          </div>
          <div class="meta">
            <h3>מברשת עיסוי קרקפת</h3>
            <p>מברשת סיליקון לעיסוי יומי שמגביר זרימת דם וחדירת הסרום.</p>
          </div>
          <div class="buy">
            <span class="ap">₪39</span>   <!-- // PRICE -->
            <!-- // ADD-TO-CART -->
            {%- if section.settings.addon_brush != blank -%}{%- assign ap = section.settings.addon_brush -%}{%- form 'product', ap -%}<input type="hidden" name="id" value="{{ ap.selected_or_first_available_variant.id }}"><button type="submit" name="add" class="add-btn">הוסף/י</button>{%- endform -%}{%- else -%}<button class="add-btn" type="button" title="בחר/י מוצר ב-Section settings">הוסף/י</button>{%- endif -%}
          </div>
        </div>
      </div>

      <!-- באנדל / דיל משתלם -->
      <div class="bundle">
        <span class="badge">הדיל המשתלם ביותר 🔥</span>
        <h3 style="font-size:22px;margin:10px 0 4px">ערכת ReGrow המלאה</h3>
        <div class="items">
          <span>מסרק ReGrow</span><span class="plus">+</span>
          <span>סרום</span><span class="plus">+</span>
          <span>שמפו/מרכך</span><span class="plus">+</span>
          <span>מברשת עיסוי</span>
        </div>
        <div class="price-row">
          <span class="price-old">₪326</span>   <!-- // PRICE — סכום פריטים בנפרד -->
          <span class="price-now">₪229</span>   <!-- // PRICE — מחיר הערכה -->
        </div>
        <div class="save">חוסך/ת ₪97 לעומת קנייה בנפרד</div>
        <!-- // ADD-TO-CART — בשלב 2 יחובר ל-variant/מוצר הערכה בשופיפיי -->
        {%- if section.settings.bundle_product != blank -%}{%- assign bp = section.settings.bundle_product -%}{%- form 'product', bp -%}<input type="hidden" name="id" value="{{ bp.selected_or_first_available_variant.id }}"><button type="submit" name="add" class="cta" style="margin-top:14px">קח/י את הערכה המלאה — {{ bp.price | money }} <span class="arrow">←</span></button>{%- endform -%}{%- else -%}<a href="#" class="cta" style="margin-top:14px">קח/י את הערכה המלאה — ₪229 <span class="arrow">←</span></a>{%- endif -%}
      </div>
    </div>
  </section>

  <!-- ===================== FAQ ===================== -->
  <section class="faq">
    <div class="wrap">
      <span class="eyebrow">שאלות נפוצות</span>
      <h2>כל מה שרצית לשאול</h2>

      <details>
        <summary>תוך כמה זמן רואים תוצאות?</summary>
        <div class="ans">רוב המשתמשים מתחילים לשים לב לשינוי בתחושת המלאות תוך מספר שבועות של שימוש עקבי. התוצאות משתנות מאדם לאדם, ולכן אנחנו ממליצים על שימוש רציף לאורך זמן.</div>
      </details>
      <details>
        <summary>האם השימוש כואב?</summary>
        <div class="ans">לא. האור האדום בעוצמה נמוכה אינו מחמם ואינו כואב — רוב האנשים מתארים תחושה נעימה ורגועה.</div>
      </details>
      <details>
        <summary>מתאים גם לגברים וגם לנשים?</summary>
        <div class="ans">בהחלט. ReGrow מתאים לכל סוגי השיער והקרקפת, לנשים עם דילול ולגברים עם נסיגת קו השיער כאחד.</div>
      </details>
      <details>
        <summary>איך מנקים את המסרק?</summary>
        <div class="ans">פשוט מנגבים את שיני המסרק במטלית יבשה או לחה מעט. אין לשטוף תחת מים זורמים.</div>
      </details>
      <details>
        <summary>מה כוללת האחריות?</summary>
        <div class="ans">כל מסרק מגיע עם 30 יום ניסיון — אם זה לא בשבילך, מחזירים ומקבלים את הכסף בחזרה, וכן אחריות יצרן על המוצר.</div>
      </details>
      <details>
        <summary>כמה זמן לוקח המשלוח?</summary>
        <div class="ans">המשלוח חינם ומגיע בדרך כלל תוך 2-4 ימי עסקים לכל הארץ.</div>
      </details>
      <details>
        <summary>מה מדיניות ההחזרות?</summary>
        <div class="ans">ניתן להחזיר את המוצר תוך 30 יום מקבלתו ולקבל החזר כספי מלא, כל עוד הוא במצב תקין.</div>
      </details>
      <details>
        <summary>האם זה בטוח לשימוש יומיומי?</summary>
        <div class="ans">כן. השימוש המומלץ הוא כ-3 פעמים בשבוע, 10 דקות בכל פעם. מומלץ להיוועץ ברופא אם יש לך מצב רפואי רלוונטי.</div>
      </details>
    </div>
  </section>

  <!-- ===================== GUARANTEE ===================== -->
  <section class="guarantee">
    <div class="wrap center">
      <div class="g-card">
        <div class="g-seal">30 יום<br>ניסיון</div>
        <h2>נסה/י ללא סיכון</h2>
        <p class="lead">תן/י ל-ReGrow 30 יום. אם לא הרגשת הבדל — פנה/י אלינו ונחזיר לך את מלוא הסכום. הסיכון כולו עלינו.</p>
      </div>
    </div>
  </section>

  <!-- ===================== FINAL CTA ===================== -->
  <section class="final">
    <div class="wrap center">
      <h2>השיער שלך מחכה — בוא/י נתחיל</h2>
      <p class="lead">מבצע לזמן מוגבל. הצטרף/י לאלפי לקוחות מרוצים.</p>
      <div class="price-row">
        {%- if product.compare_at_price > product.price -%}<span class="price-old">{{ product.compare_at_price | money }}</span>{%- endif -%}
        <span class="price-now">{{ product.price | money }}</span>
      </div>
      <a href="#offer" class="cta" style="margin-top:14px">אני רוצה שיער מלא יותר <span class="arrow">←</span></a>
    </div>
  </section>

  <footer>
    © <span id="yr"></span> ReGrow <!-- BRAND -->. כל הזכויות שמורות. · המידע באתר אינו מהווה ייעוץ רפואי.
  </footer>

  <!-- ===================== CTA דביק במובייל ===================== -->
  <div class="sticky-cta" aria-label="קנייה מהירה">
    <div class="sp">
      <b>{{ product.price | money }}</b>
      {%- if product.compare_at_price > product.price -%}<s>{{ product.compare_at_price | money }}</s>{%- endif -%}
    </div>
    <!-- // ADD-TO-CART -->
    <a href="#offer" class="cta">הוסף/י לעגלה <span class="arrow">←</span></a>
  </div>

  <script>
    // שנה נוכחית ב-footer (ללא localStorage/sessionStorage)
    document.getElementById('yr').textContent = new Date().getFullYear();

    // סליידר לפני/אחרי — מעדכן את משתנה --pos לפי הגרירה
    document.querySelectorAll('.ba-slider').forEach(function(slider){
      var range = slider.querySelector('input[type=range]');
      if(!range) return;
      var update = function(){ slider.style.setProperty('--pos', range.value); };
      range.addEventListener('input', update);
      update();
    });
  </script>
</div>
{% schema %}
{
  "name": "ReGrow — דף מוצר",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "cta_text", "label": "טקסט כפתור הקנייה", "default": "הוסף/י לעגלה" },
    { "type": "text", "id": "urgency_text", "label": "שורת דחיפות", "default": "⏳ מלאי מוגבל — המבצע בתוקף עד גמר המלאי" },
    { "type": "header", "content": "מוצרים משלימים — קישור לעגלה" },
    { "type": "paragraph", "content": "בחר/י לכל מוצר את הפריט המתאים בחנות, וכפתור 'הוסף/י' יוסיף אותו לעגלה." },
    { "type": "product", "id": "addon_serum", "label": "מוצר: סרום לצמיחת שיער" },
    { "type": "product", "id": "addon_shampoo", "label": "מוצר: שמפו / מרכך" },
    { "type": "product", "id": "addon_brush", "label": "מוצר: מברשת עיסוי קרקפת" },
    { "type": "product", "id": "bundle_product", "label": "מוצר: ערכת ReGrow המלאה (באנדל)" }
  ],
  "presets": [ { "name": "ReGrow — דף מוצר" } ]
}
{% endschema %}
