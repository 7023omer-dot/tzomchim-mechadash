        {%- if product.compare_at_price > product.price -%}<div class="save">חוסך/ת {{ product.compare_at_price | minus: product.price | money }}</div>{%- endif -%}
        {%- else -%}
        <div class="price-row"><span class="price-old">₪219</span><span class="price-now">₪148</span></div>
        <div class="save">חיסכון 32% · 71 ₪</div>
        {%- endif -%}
        <div class="urgency">{{ section.settings.urgency_text | default: '⏳ מלאי מוגבל — המבצע בתוקף עד גמר המלאי' }}</div>
        {%- if product -%}
        {%- form 'product', product -%}
          {%- unless product.has_only_default_variant -%}
            <select name="id" class="variant-select" aria-label="בחר/י אפשרות">
              {%- for v in product.variants -%}
                <option value="{{ v.id }}" {% unless v.available %}disabled{% endunless %}>{{ v.title }} — {{ v.price | money }}</option>
              {%- endfor -%}
            </select>
          {%- else -%}
            <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
          {%- endunless -%}
          <button type="submit" name="add" class="cta" {% unless product.available %}disabled{% endunless %}>
            {%- if product.available -%}{{ section.settings.cta_text | default: 'הוסף/י לעגלה' }} — {{ product.price | money }}{%- else -%}אזל מהמלאי{%- endif -%}
            <span class="arrow">←</span>
          </button>
          {{ form | payment_button }}
        {%- endform -%}
        {%- else -%}
        <a href="/pages/catalog" class="cta">{{ section.settings.cta_text | default: 'הוסף/י לעגלה' }} <span class="arrow">←</span></a>
        {%- endif -%}
        <div class="trustbar">
          <span>🚚 משלוח חינם</span>
          <span>🔒 תשלום מאובטח</span>
        </div>
        <div class="pay" aria-label="אמצעי תשלום">
          <span class="lbl">תשלום מאובטח באמצעות</span>
          <span class="chip">VISA</span>
          <span class="chip">Mastercard</span>
          <span class="chip">American Express</span>
          <span class="chip">bit</span>
          <span class="chip">PayPal</span>
          <span class="chip">Apple&nbsp;Pay</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== מוצרים משלימים + באנדל ===================== -->
  <section class="addons">
    <div class="wrap">
      <span class="eyebrow">מבצעי קומבו</span>
      <h2>המסרק לבד — או חוסכים עם קומבו</h2>
      <p class="lead">המסרק לבד נשאר ב-219 ₪. ההנחה נפתחת ברגע שמוסיפים מוצר — ככל שמשלבים יותר, חוסכים יותר.</p>

      <div class="combo-grid">
        <!-- מבצע 1 — מסרק + סרום -->
        <div class="bundle combo">
          <span class="badge">הקומבו המנצח 🔥</span>
          <div class="combo-imgs">
            <img src="{{ 'tz-comb.webp' | asset_url }}" alt="מסרק אינפרא אדום" loading="lazy">
            <span class="plus">+</span>
            <img src="{{ 'tz-ghkcu.webp' | asset_url }}" alt="סרום GHK-CU" loading="lazy">
          </div>
          <h3 style="font-size:20px;margin:8px 0 4px">מסרק + סרום</h3>
          <div class="items"><span>מסרק אינפרא אדום</span><span class="plus">+</span><span>סרום GHK-CU</span></div>
          <div class="price-row"><span class="price-old">₪278</span><span class="price-now">₪207</span></div>
          <div class="save">חוסך/ת 71 ₪ · 26%</div>
          {%- assign cc = section.settings.combo_comb -%}
          {%- assign cse = section.settings.addon_serum -%}
          {%- assign csh = section.settings.addon_shampoo -%}
          {%- if section.settings.combo_serum != blank -%}{%- assign cs = section.settings.combo_serum -%}{%- form 'product', cs -%}<input type="hidden" name="id" value="{{ cs.selected_or_first_available_variant.id }}"><button type="submit" name="add" class="cta" style="margin-top:14px">הוסיפו את הקומבו לסל — {{ cs.price | money }} <span class="arrow">←</span></button>{%- endform -%}{%- elsif cc != blank and cse != blank -%}<button type="button" class="cta" data-combo-add="{{ cc.selected_or_first_available_variant.id }},{{ cse.selected_or_first_available_variant.id }}" style="margin-top:14px">הוסיפו את הקומבו לסל — ₪207 <span class="arrow">←</span></button>{%- else -%}<a href="#offer" class="cta" style="margin-top:14px">הוסיפו את הקומבו לסל — ₪207 <span class="arrow">←</span></a>{%- endif -%}
        </div>

        <!-- מבצע 2 — מסרק + סרום + שמפו (הכי משתלם) -->
        <div class="bundle combo best">
          <span class="badge gold">הכי משתלם ⭐</span>
          <div class="combo-imgs">
            <img src="{{ 'tz-comb.webp' | asset_url }}" alt="מסרק אינפרא אדום" loading="lazy">
            <span class="plus">+</span>
            <img src="{{ 'tz-ghkcu.webp' | asset_url }}" alt="סרום GHK-CU" loading="lazy">
            <span class="plus">+</span>
            <img src="{{ 'tz-spartan.webp' | asset_url }}" alt="שמפו Spartan" loading="lazy">
          </div>
          <h3 style="font-size:20px;margin:8px 0 4px">הערכה המלאה — מסרק + סרום + שמפו</h3>
          <div class="items"><span>מסרק</span><span class="plus">+</span><span>סרום GHK-CU</span><span class="plus">+</span><span>שמפו Spartan</span></div>
          <div class="price-row"><span class="price-old">₪327</span><span class="price-now">₪239</span></div>
          <div class="save">חוסך/ת 88 ₪ · 27%</div>
          {%- if section.settings.combo_brush != blank -%}{%- assign cb = section.settings.combo_brush -%}{%- form 'product', cb -%}<input type="hidden" name="id" value="{{ cb.selected_or_first_available_variant.id }}"><button type="submit" name="add" class="cta" style="margin-top:14px">הוסיפו את הערכה לסל — {{ cb.price | money }} <span class="arrow">←</span></button>{%- endform -%}{%- elsif cc != blank and cse != blank and csh != blank -%}<button type="button" class="cta" data-combo-add="{{ cc.selected_or_first_available_variant.id }},{{ cse.selected_or_first_available_variant.id }},{{ csh.selected_or_first_available_variant.id }}" style="margin-top:14px">הוסיפו את הערכה לסל — ₪239 <span class="arrow">←</span></button>{%- else -%}<a href="#offer" class="cta" style="margin-top:14px">הוסיפו את הערכה לסל — ₪239 <span class="arrow">←</span></a>{%- endif -%}
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== FAQ ===================== -->
  <section class="faq">
    <div class="wrap">
      <span class="eyebrow">שאלות נפוצות</span>
      <h2>כל מה שרצית לשאול</h2>

      <details>
        <summary>תוך כמה זמן רואים תוצאות?</summary>
        <div class="ans">רוב המשתמשים מתחילים לשים לב לשינוי בתחושת המלאות תוך מספר שבועות של שימוש עקבי. התוצאות משתנות מאדם לאדם, ולכן אנחנו ממליצים על שימוש רציף לאורך זמן.</div>
      </details>
      <details>
        <summary>האם השימוש כואב?</summary>
        <div class="ans">לא. האור האדום בעוצמה נמוכה אינו מחמם ואינו כואב — רוב האנשים מתארים תחושה נעימה ורגועה.</div>
      </details>
      <details>
        <summary>מתאים גם לגברים וגם לנשים?</summary>
        <div class="ans">בהחלט. צומחים מחדש מתאים לכל סוגי השיער והקרקפת, לנשים עם דילול ולגברים עם נסיגת קו השיער כאחד.</div>
      </details>
      <details>
        <summary>מתאים גם לקרחת מתקדמת?</summary>
        <div class="ans">המכשיר עובד הכי טוב כשיש עדיין זקיקים פעילים — כלומר בדילול ובהקלשה. במצב של קרחת מתקדמת לאורך שנים התוצאות מוגבלות יותר, ומומלץ להיוועץ עם איש מקצוע לפני רכישה.</div>
      </details>
      <details>
        <summary>איך מנקים את המסרק?</summary>
        <div class="ans">פשוט מנגבים את שיני המסרק במטלית יבשה או לחה מעט. אין לשטוף תחת מים זורמים.</div>
      </details>
      <details>
        <summary>מה כוללת האחריות?</summary>
        <div class="ans">כל מסרק מגיע עם אחריות יצרן, וניתן להחזיר בהתאם למדיניות ההחזרות שלנו.</div>
      </details>
      <details>
        <summary>כמה זמן לוקח המשלוח?</summary>
        <div class="ans">המשלוח חינם ומגיע בדרך כלל תוך 2-4 ימי עסקים לכל הארץ.</div>
      </details>
      <details>
        <summary>מה מדיניות ההחזרות?</summary>
        <div class="ans">ניתן להחזיר את המוצר בהתאם למדיניות ההחזרות שלנו, כל עוד הוא במצב תקין.</div>
      </details>
      <details>
        <summary>האם זה בטוח לשימוש יומיומי?</summary>
        <div class="ans">כן. השימוש המומלץ הוא כ-3 פעמים בשבוע, 10 דקות בכל פעם. מומלץ להיוועץ ברופא אם יש לך מצב רפואי רלוונטי.</div>
      </details>
    </div>
  </section>

  <!-- ===================== FINAL CTA ===================== -->
  <section class="final">
    <div class="wrap center">
      <h2>השיער שלך מחכה — בוא/י נתחיל</h2>
      <p class="lead">מבצע לזמן מוגבל. הצטרף/י לאלפי לקוחות מרוצים.</p>
      <div class="price-row">
        {%- if product.compare_at_price > product.price -%}<span class="price-old">{{ product.compare_at_price | money }}</span>{%- endif -%}
        <span class="price-now">{{ product.price | money }}</span>
      </div>
      <a href="#offer" class="cta" style="margin-top:14px">אני רוצה שיער מלא יותר <span class="arrow">←</span></a>
    </div>
  </section>

  <footer>
    © <span id="yr"></span> צומחים מחדש <!-- BRAND -->. כל הזכויות שמורות. · המידע באתר אינו מהווה ייעוץ רפואי.
  </footer>

  <!-- ===================== CTA דביק במובייל ===================== -->
  <div class="sticky-cta" aria-label="קנייה מהירה">
    <div class="sp">
      <span style="font-size:13px;font-weight:700;color:#111">מסרק צומחים מחדש</span>
      <b>{{ product.price | money }}</b>
      {%- if product.compare_at_price > product.price -%}<s>{{ product.compare_at_price | money }}</s>{%- endif -%}
    </div>
    <!-- // ADD-TO-CART -->
    <a href="#offer" class="cta">הוסף/י לעגלה <span class="arrow">←</span></a>
  </div>

  <script>
    // שנה נוכחית ב-footer (ללא localStorage/sessionStorage)
    document.getElementById('yr').textContent = new Date().getFullYear();

    // סליידר לפני/אחרי — מעדכן את משתנה --pos לפי הגרירה
    document.querySelectorAll('.ba-slider').forEach(function(slider){
      var range = slider.querySelector('input[type=range]');
      if(!range) return;
      var update = function(){ slider.style.setProperty('--pos', range.value); };
      range.addEventListener('input', update);
      update();
    });

    // סרטון — כפתור Play מפעיל עם קול מלא (לא מושתק); הכפתור נעלם בזמן ניגון
    document.querySelectorAll('[data-rg-video]').forEach(function(w){
      var v = w.querySelector('video');
      var b = w.querySelector('.rg-play');
      var lbl = w.querySelector('.rg-vlabel');
      if(!v || !b) return;
      b.addEventListener('click', function(){ v.play(); });
      v.addEventListener('play', function(){ b.hidden = true; if(lbl) lbl.hidden = true; });
      v.addEventListener('ended', function(){ b.hidden = false; if(lbl) lbl.hidden = false; });
    });

    // קומבו — הוספת רכיבים לסל; ה-Automatic Discount מחיל את מחיר הקומבו
    document.querySelectorAll('[data-combo-add]').forEach(function(btn){
      btn.addEventListener('click', function(){
        var items = btn.getAttribute('data-combo-add').split(',').map(function(x){
          return { id: parseInt(x, 10), quantity: 1 };
        }).filter(function(i){ return i.id; });
        if(!items.length) return;
        btn.setAttribute('aria-busy', 'true');
        fetch('{{ routes.cart_add_url }}.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ items: items })
        }).then(function(){ window.location.href = '{{ routes.cart_url }}'; })
          .catch(function(){ window.location.href = '{{ routes.cart_url }}'; });
      });
    });
  </script>
</div>
