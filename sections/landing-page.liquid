      <div class="cfoot">או כתבו ישירות ל־<a href="mailto:growagain18@gmail.com">growagain18@gmail.com</a></div>
    </div>
    <button type="button" class="scm-cbtn" data-ctoggle aria-label="צרו קשר">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 7l9 6 9-6"/></svg>
      <span class="ctxt">צרו קשר</span>
    </button>
  </div>

  <script>
  (function(){
    var root = document.currentScript.closest('.scm-page');
    if(!root) return;

    // הודעת אזהרה — סגירה ושמירה
    var warn = root.querySelector('[data-warn]');
    if(warn){
      try{ if(localStorage.getItem('scm-warn-closed')==='1'){ warn.hidden = true; } }catch(e){}
      var wx = warn.querySelector('[data-warn-x]');
      if(wx){ wx.addEventListener('click', function(){ warn.hidden = true; try{ localStorage.setItem('scm-warn-closed','1'); }catch(e){} }); }
    }

    // צ'קבוקס אישור תקנון — חוסם רכישה
    var termsBox = root.querySelector('[data-terms]');
    var termsWrap = root.querySelector('[data-terms-wrap]');
    function termsOK(){
      if(!termsBox || termsBox.checked) return true;
      if(termsWrap){
        termsWrap.classList.remove('warn');
        void termsWrap.offsetWidth;
        termsWrap.classList.add('warn');
        termsWrap.scrollIntoView({behavior:'smooth',block:'center'});
      }
      return false;
    }
    if(termsBox){ termsBox.addEventListener('change', function(){ if(termsBox.checked && termsWrap) termsWrap.classList.remove('warn'); }); }
    // חסימת טופס "הוספה לסל" של הכרטיס הבסיסי
    root.querySelectorAll('form[action*="/cart/add"]').forEach(function(f){
      f.addEventListener('submit', function(e){ if(!termsOK()){ e.preventDefault(); } });
    });

    // הוספת קומבו לסל
    root.querySelectorAll('[data-combo-add]').forEach(function(btn){
      btn.addEventListener('click', function(){
        if(!termsOK()) return;
        var items = btn.getAttribute('data-combo-add').split(',').map(function(x){return {id:parseInt(x,10),quantity:1};}).filter(function(i){return i.id;});
        if(!items.length) return;
        btn.setAttribute('aria-busy','true');
        fetch('{{ routes.cart_add_url }}.js',{method:'POST',headers:{'Content-Type':'application/json','Accept':'application/json'},body:JSON.stringify({items:items})})
          .then(function(){window.location.href='{{ routes.cart_url }}';})
          .catch(function(){window.location.href='{{ routes.cart_url }}';});
      });
    });

    // גלילה חלקה לעוגנים
    root.querySelectorAll('a[href^="#"]').forEach(function(a){
      a.addEventListener('click',function(e){
        var id=a.getAttribute('href'); if(id.length<2) return;
        var t=document.querySelector(id); if(!t) return;
        e.preventDefault(); t.scrollIntoView({behavior:'smooth',block:'start'});
      });
    });

    // כפתור "לחצו כאן ←" שמופיע בסוף הסרטון ומפנה לכרטיסי הקנייה
    var vbox = root.querySelector('[data-vbox]');
    if(vbox){
      var vid = vbox.querySelector('video'), vcta = vbox.querySelector('[data-vcta]');
      if(vid && vcta){
        vid.addEventListener('ended', function(){ vcta.classList.add('show'); });
        vid.addEventListener('play',  function(){ vcta.classList.remove('show'); });
        vid.addEventListener('timeupdate', function(){
          if(vid.duration && (vid.duration - vid.currentTime) <= 2.5){ vcta.classList.add('show'); }
        });
      }
    }

    // חשיפה עדינה בגלילה (scroll-reveal)
    var rmq = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)');
    if((!rmq || !rmq.matches) && 'IntersectionObserver' in window){
      var revs = root.querySelectorAll('.sec-head, .ba .card, .ocard, .how .step, .rcard, .faq details, .compare .scroll, .video-sec .vtext, .video-sec .box, .hero .copy, .hero .media');
      var io = new IntersectionObserver(function(entries){
        entries.forEach(function(en){ if(en.isIntersecting){ en.target.classList.add('in'); io.unobserve(en.target); } });
      },{threshold:.1, rootMargin:'0px 0px -7% 0px'});
      revs.forEach(function(el,i){
        if(el.classList.contains('best')) return; /* לא לפגוע בהגדלת הכרטיס המומלץ */
        el.classList.add('reveal'); el.style.transitionDelay=((i%3)*0.08)+'s'; io.observe(el);
      });
    }

    // התראת "נרכש עכשיו" — מחזורית (שמות לדוגמה)
    var toast = root.querySelector('[data-toast]');
    if(toast){
      var buys = [
        ['שיר ביטון','רכשה','הערכה המלאה','לפני 4 דקות'],
        ['עידו דגן','רכש','מסרק + סרום','לפני 9 דקות'],
        ['נועה פרץ','רכשה','הערכה המלאה','לפני 14 דקות'],
        ['אורי כהן','רכש','מסרק אינפרא אדום','לפני 19 דקות'],
        ['מאיה לוי','רכשה','מסרק + סרום','לפני 27 דקות'],
        ['רן אזולאי','רכש','הערכה המלאה','לפני 33 דקות'],
        ['טל שרעבי','רכשה','מסרק + סרום','לפני 41 דקות'],
        ['יונתן מלכה','רכש','הערכה המלאה','לפני 52 דקות']
      ];
      var nm=toast.querySelector('[data-tname]'), vb=toast.querySelector('[data-tverb]'), pr=toast.querySelector('[data-tprod]'), ag=toast.querySelector('[data-tago]'), bi=0;
      function showToast(){
        var b=buys[bi % buys.length]; bi++;
        nm.textContent=b[0]; vb.textContent=b[1]; pr.textContent=b[2]; ag.textContent='✓ '+b[3];
        toast.hidden=false; requestAnimationFrame(function(){ toast.classList.add('show'); });
        setTimeout(function(){ toast.classList.remove('show'); setTimeout(function(){ toast.hidden=true; }, 400); }, 5200);
      }
      setTimeout(function(){ showToast(); setInterval(showToast, 11000); }, 3500);
    }

    // כפתור מייל צף + טופס
    var contact = root.querySelector('[data-contact]');
    if(contact){
      var form = contact.querySelector('.scm-cform');
      var toggle = contact.querySelector('[data-ctoggle]');
      var txt = toggle.querySelector('.ctxt');
      function openForm(open){ form.hidden = !open; if(txt) txt.textContent = open ? 'סגירה' : 'צרו קשר'; }
      toggle.addEventListener('click', function(){ openForm(form.hidden); });
      root.querySelectorAll('[data-open-contact]').forEach(function(el){
        el.addEventListener('click', function(e){ e.preventDefault(); openForm(true); });
      });
      var send = contact.querySelector('[data-csend]');
      send.addEventListener('click', function(){
        var name=(contact.querySelector('[data-cname]').value||'').trim();
        var email=(contact.querySelector('[data-cemail]').value||'').trim();
        var msg=(contact.querySelector('[data-cmsg]').value||'').trim();
        var subj='פנייה מהאתר — צומחים מחדש'+(name?' · '+name:'');
        var body='שם: '+name+'\nמייל לחזרה: '+email+'\n\n'+msg;
        window.location.href='mailto:growagain18@gmail.com?subject='+encodeURIComponent(subj)+'&body='+encodeURIComponent(body);
      });
    }
  })();
  </script>
</div>

