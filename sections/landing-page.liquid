{% comment %}
  צומחים מחדש — section דף מוצר לשופיפיי (גרסה רזה, ללא base64)
  • תמונת HERO נמשכת מתמונת המוצר; תמונת האפליקטור מהגדרות הסקשן.
  • מחיר + כל כפתורי 'הוסף לעגלה' מחוברים למוצרים אמיתיים (צ'קאאוט אמיתי).
{% endcomment %}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Heebo:wght@400;500;700;800;900&display=swap" rel="stylesheet">
<style>
    /* ============ משתני מותג (פלטה חמה ונקייה) ============ */
    .regrow-page{
      --cream:#F4EBDD;        /* רקע שמנת פרימיום */
      --cream-soft:#FBF6EE;   /* שמנת בהיר יותר */
      --white:#FFFFFF;
      --ink:#2B2B2B;          /* טקסט ראשי — חום-שחור רך */
      --muted:#6B6B6B;        /* טקסט משני — ניגודיות טובה */
      --terracotta:#E8112D;   /* אדום מותג — CTA/מבצע/אקסנט */
      --terracotta-dark:#C20E26;
      --black:#1E1A17;        /* כהה רך לפוטר */
      --gold:#E8112D;         /* באדג'ים — אדום מותג */
      --line:#E7DECF;
      --ok:#1E9E57;
      --star:#F5A623;
      --shadow:0 8px 30px rgba(60,45,30,.08);
      --shadow-lg:0 16px 48px rgba(60,45,30,.14);
      --radius:18px;
      --radius-sm:12px;
      --maxw:680px;           /* mobile-first; דסקטופ מתרחב למטה */
    }

    .regrow-page *{box-sizing:border-box;margin:0;padding:0}
    .regrow-page{scroll-behavior:smooth}
    .regrow-page{
      font-family:'Heebo',system-ui,Arial,sans-serif;
      background:var(--cream);
      color:var(--ink);
      line-height:1.6;
      font-size:17px;
      -webkit-font-smoothing:antialiased;
      padding-bottom:84px; /* מקום ל-CTA דביק במובייל */
    }
    .regrow-page img{max-width:100%;display:block}
    .regrow-page svg{max-width:100%;max-height:44px}            /* בטיחות: מונע אייקונים ענקיים */
    .regrow-page .benefit .bic svg,.regrow-page .trustbar svg{width:22px;height:22px}
    .regrow-page section{padding:46px 20px}
    .regrow-page .wrap{max-width:var(--maxw);margin:0 auto}
    .regrow-page h1, .regrow-page h2, .regrow-page h3{line-height:1.2;font-weight:800;letter-spacing:-.01em}
    .regrow-page h2{font-size:28px;margin-bottom:10px}
    .regrow-page .lead{color:var(--muted);font-size:18px}
    .regrow-page .center{text-align:center}
    .regrow-page .eyebrow{
      display:inline-block;color:var(--terracotta);font-weight:700;
      font-size:14px;letter-spacing:.04em;text-transform:none;margin-bottom:10px;
    }

    /* ============ כפתורי CTA ============ */
    .regrow-page .cta{
      display:inline-flex;align-items:center;justify-content:center;gap:8px;
      background:var(--terracotta);color:#fff;border:none;cursor:pointer;
      font-family:inherit;font-weight:800;font-size:19px;
      padding:17px 30px;border-radius:999px;width:100%;max-width:420px;
      box-shadow:0 8px 22px rgba(232,17,45,.28);
      transition:transform .15s ease,box-shadow .15s ease,background .15s ease;
      text-decoration:none;
    }
    .regrow-page .cta:hover{background:var(--terracotta-dark);transform:translateY(-2px);box-shadow:0 12px 28px rgba(232,17,45,.40)}
    .regrow-page .cta:active{transform:translateY(0)}
    .regrow-page .cta .arrow{font-size:22px;line-height:1}

    /* ============ שורת אמון ============ */
    .regrow-page .trustbar{
      display:flex;flex-wrap:wrap;justify-content:center;gap:18px;
      margin-top:18px;color:var(--muted);font-size:14px;font-weight:500;
    }
    .regrow-page .trustbar span{display:inline-flex;align-items:center;gap:6px}
    .regrow-page .ic{width:20px;height:20px;flex:0 0 auto;color:var(--terracotta)}

    /* ============ HERO ============ */
    .regrow-page .hero{background:var(--cream);padding:30px 20px 40px}
    .regrow-page .hero .eyebrow{color:var(--terracotta)}
    .regrow-page .hero h1{color:var(--ink);font-size:30px;font-weight:900;margin-bottom:14px;line-height:1.16}
    .regrow-page .hero h1 em{font-style:normal;color:var(--terracotta)}
    .regrow-page .hero .lead{color:var(--muted);font-size:17px;margin-bottom:20px}
    /* פריסת שני טורים: תמונה | כותרת+יתרונות (מובייל: תמונה למעלה) */
    .regrow-page .hero-duo{display:flex;flex-direction:column;gap:22px;align-items:center}
    .regrow-page .hero-media{width:100%;max-width:360px}
    .regrow-page .hero-media .pimg{background:#fff;border-radius:var(--radius);box-shadow:var(--shadow-lg);padding:14px;min-height:0}
    .regrow-page .hero-media .pimg img{width:100%;height:auto;display:block}
    .regrow-page .hero-copy{width:100%}
    .regrow-page .hero .trustbar{color:var(--muted)}
    /* רשימת יתרונות — כרטיסים מסודרים, אייקון ✓ אדום */
    .regrow-page .hero-benefits{list-style:none;display:grid;grid-template-columns:1fr;gap:9px;margin:0 0 22px;text-align:right}
    .regrow-page .hero-benefits li{display:flex;align-items:center;gap:11px;font-size:16px;font-weight:600;color:var(--ink);background:#fff;border:1px solid var(--line);border-radius:12px;padding:11px 14px;box-shadow:var(--shadow)}
    .regrow-page .hero-benefits .hb-ic{flex:0 0 auto;width:32px;height:32px;border-radius:50%;background:var(--terracotta);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:900;font-size:17px}
    /* placeholder תמונה — החלף ב-<img src="..."> */
    .regrow-page .ph{
      display:flex;align-items:center;justify-content:center;text-align:center;
      background:repeating-linear-gradient(45deg,#F2F2F2,#F2F2F2 12px,#E8E8E8 12px,#E8E8E8 24px);
      color:#999999;font-weight:600;font-size:14px;padding:24px;min-height:220px;
    }

    /* ציור מוצר (SVG) במקום placeholder */
    .regrow-page .pimg{display:flex;align-items:center;justify-content:center;background:radial-gradient(circle at 50% 36%,#ffffff,#F5F5F5);padding:16px;min-height:220px}
    .regrow-page .pimg svg{width:auto;height:100%;max-height:240px;max-width:100%;display:block}
    .regrow-page .addon .pimg{width:96px;height:96px;min-height:0;padding:8px;border-radius:12px;flex:0 0 auto}

    .regrow-page .hero-img img{width:100%;height:auto;display:block}
    .regrow-page .solution .card .solpic{width:100%;border-radius:12px;margin-bottom:16px;display:block}

    /* ============ PROBLEM ============ */
    .regrow-page .problem{background:var(--white)}
    .regrow-page .pain-list{list-style:none;margin-top:20px;display:grid;gap:14px}
    .regrow-page .pain-list li{
      display:flex;gap:12px;align-items:flex-start;background:var(--cream);
      border:1px solid var(--line);border-radius:var(--radius-sm);padding:16px 18px;
    }
    .regrow-page .pain-list .dot{color:var(--terracotta);font-size:22px;line-height:1.3;flex:0 0 auto}

    /* ============ SOLUTION ============ */
    .regrow-page .solution{background:var(--cream)}
    .regrow-page .solution .card{
      background:#fff;border-radius:var(--radius);box-shadow:var(--shadow);
      padding:26px;margin-top:18px;
    }

    /* ============ HOW IT WORKS ============ */
    .regrow-page .how{background:var(--white)}
    .regrow-page .steps{display:grid;gap:18px;margin-top:24px}
    .regrow-page .step{display:flex;gap:16px;align-items:flex-start}
    .regrow-page .step .num{
      flex:0 0 auto;width:46px;height:46px;border-radius:50%;
      background:var(--terracotta);color:#fff;font-weight:800;font-size:20px;
      display:flex;align-items:center;justify-content:center;
    }
    .regrow-page .step h3{font-size:19px;margin-bottom:2px}
    .regrow-page .step p{color:var(--muted);font-size:16px}

    /* ============ BENEFITS ============ */
    .regrow-page .benefits{background:var(--cream)}
    .regrow-page .grid{display:grid;grid-template-columns:1fr;gap:14px;margin-top:24px}
    .regrow-page .benefit{
      background:#fff;border-radius:var(--radius-sm);padding:20px;
      box-shadow:var(--shadow);display:flex;gap:14px;align-items:flex-start;
    }
    .regrow-page .benefit .bic{
      flex:0 0 auto;width:42px;height:42px;border-radius:12px;
      background:#FDE7E9;color:var(--terracotta);display:flex;
      align-items:center;justify-content:center;
    }
    .regrow-page .benefit h3{font-size:17px;margin-bottom:2px}
    .regrow-page .benefit p{color:var(--muted);font-size:15px}

    /* ============ BEFORE / AFTER ============ */
    .regrow-page .ba{background:var(--white)}
    .regrow-page .ba-grid{display:grid;grid-template-columns:1fr;gap:18px;margin-top:24px}
    .regrow-page .ba-card{border-radius:var(--radius);overflow:hidden;box-shadow:var(--shadow);background:#fff}
    .regrow-page .ba-card .cap{padding:12px 16px;font-weight:600;color:var(--ink);text-align:center}
    .regrow-page .disclaimer{color:var(--muted);font-size:13px;text-align:center;margin-top:16px;font-style:italic}

    /* ============ SOCIAL PROOF ============ */
    .regrow-page .reviews{background:var(--cream)}
    .regrow-page .rating-top{display:flex;align-items:center;justify-content:center;gap:10px;margin:14px 0 6px}
    .regrow-page .rating-top .big{font-size:34px;font-weight:900}
    .regrow-page .stars{color:var(--star);font-size:20px;letter-spacing:2px}
    .regrow-page .review-grid{display:grid;gap:16px;margin-top:24px}
    .regrow-page .review{
      background:#fff;border-radius:var(--radius-sm);padding:20px;box-shadow:var(--shadow);
    }
    .regrow-page .review .who{display:flex;align-items:center;gap:12px;margin-bottom:10px}
    .regrow-page .review .av{
      width:44px;height:44px;border-radius:50%;background:#FDE7E9;color:var(--terracotta);
      font-weight:800;display:flex;align-items:center;justify-content:center;flex:0 0 auto;
    }
    .regrow-page .review .name{font-weight:700;font-size:15px}
    .regrow-page .review .stars{font-size:15px;letter-spacing:1px}
    .regrow-page .verified{color:var(--ok);font-size:12px;font-weight:600;display:inline-flex;gap:4px;align-items:center}

    /* ============ COMPARISON ============ */
    .regrow-page .compare{background:var(--white)}
    .regrow-page .table-scroll{overflow-x:auto;margin-top:22px;-webkit-overflow-scrolling:touch}
    .regrow-page table.cmp{width:100%;border-collapse:collapse;min-width:480px;background:#fff;border-radius:var(--radius-sm);overflow:hidden;box-shadow:var(--shadow)}
    .regrow-page table.cmp th, .regrow-page table.cmp td{padding:14px 12px;text-align:center;border-bottom:1px solid var(--line);font-size:15px}
    .regrow-page table.cmp thead th{background:var(--ink);color:#fff;font-weight:700}
    .regrow-page table.cmp thead th.us{background:var(--terracotta)}
    .regrow-page table.cmp td:first-child, .regrow-page table.cmp th:first-child{text-align:right;font-weight:600;background:var(--cream)}
    .regrow-page table.cmp td.us{background:#FDE7E9;font-weight:700;color:var(--terracotta-dark)}
    .regrow-page .yes{color:var(--ok);font-weight:800}
    .regrow-page .no{color:#C0392B;font-weight:800}

    /* ============ OFFER / PRICING ============ */
    .regrow-page .offer{background:linear-gradient(180deg,var(--cream),#FFFDFB)}
    .regrow-page .price-card{
      position:relative;background:#fff;border:2px solid var(--terracotta);border-radius:var(--radius);
      padding:48px 24px 28px;margin:20px auto 0;max-width:460px;box-shadow:var(--shadow-lg);text-align:center;overflow:hidden;
    }
    .regrow-page .offer-head{position:absolute;top:0;inset-inline:0;background:var(--terracotta);color:#fff;font-weight:800;font-size:15px;padding:9px 12px;letter-spacing:.02em}
    .regrow-page .badge{
      display:inline-block;background:var(--gold);color:#fff;font-weight:800;
      font-size:13px;padding:6px 14px;border-radius:999px;margin-bottom:14px;
    }
    .regrow-page .price-row{display:flex;align-items:baseline;justify-content:center;gap:12px;margin:8px 0}
    .regrow-page .price-old{color:var(--muted);text-decoration:line-through;font-size:22px}      /* // PRICE */
    .regrow-page .price-now{color:var(--terracotta);font-size:46px;font-weight:900}              /* // PRICE */
    .regrow-page .save{color:var(--ok);font-weight:700;font-size:15px;margin-bottom:8px}
    .regrow-page .urgency{
      color:var(--terracotta-dark);font-weight:600;font-size:14px;margin:14px 0 18px;
      display:inline-flex;align-items:center;gap:6px;
    }
    /* ============ טיימר ספירה לאחור ============ */
    .regrow-page .rg-timer{margin:16px 0 18px}
    .regrow-page .rg-timer-label{font-size:14px;font-weight:800;color:var(--terracotta);margin-bottom:10px}
    .regrow-page .rg-timer-clock{display:flex;align-items:center;justify-content:center;gap:7px;direction:ltr}
    .regrow-page .rg-tbox{background:var(--black);color:#fff;border-radius:12px;padding:9px 8px;min-width:58px;display:flex;flex-direction:column;align-items:center}
    .regrow-page .rg-tbox span{font-size:26px;font-weight:900;line-height:1;font-variant-numeric:tabular-nums}
    .regrow-page .rg-tbox small{font-size:10px;opacity:.82;margin-top:4px;font-weight:600}
    .regrow-page .rg-tsep{font-size:22px;font-weight:900;color:var(--terracotta);line-height:1}
    /* ============ חותם אחריות ============ */
    .regrow-page .guarantee-row{display:flex;align-items:center;gap:12px;justify-content:center;text-align:right;
      background:#fff;border:1.5px solid var(--line);border-radius:14px;padding:12px 16px;margin:16px auto 4px;max-width:420px}
    .regrow-page .gr-seal{flex:0 0 auto;width:54px;height:54px;border-radius:50%;background:var(--terracotta);color:#fff;
      display:flex;flex-direction:column;align-items:center;justify-content:center;font-weight:900;font-size:20px;line-height:.9}
    .regrow-page .gr-seal small{font-size:10px;font-weight:700;margin-top:2px}
    .regrow-page .gr-text{display:flex;flex-direction:column;line-height:1.3}
    .regrow-page .gr-text b{font-size:15px;color:var(--ink)}
    .regrow-page .gr-text span{font-size:12.5px;color:var(--muted)}

    /* ============ FAQ ============ */
    .regrow-page .faq{background:var(--white)}
    .regrow-page .faq details{
      background:var(--cream);border:1px solid var(--line);border-radius:var(--radius-sm);
      margin-top:12px;overflow:hidden;
    }
    .regrow-page .faq summary{
      cursor:pointer;list-style:none;padding:18px 20px;font-weight:700;font-size:16px;
      display:flex;justify-content:space-between;align-items:center;gap:12px;
    }
    .regrow-page .faq summary::-webkit-details-marker{display:none}
    .regrow-page .faq summary::after{content:"+";color:var(--terracotta);font-size:24px;font-weight:800;line-height:1}
    .regrow-page .faq details[open] summary::after{content:"−"}
    .regrow-page .faq .ans{padding:0 20px 18px;color:var(--muted);font-size:16px}

    /* ============ GUARANTEE ============ */
    .regrow-page .guarantee{background:var(--cream)}
    .regrow-page .g-card{
      background:#fff;border-radius:var(--radius);box-shadow:var(--shadow);
      padding:30px 24px;margin-top:18px;text-align:center;border:1px dashed var(--gold);
    }
    .regrow-page .g-seal{
      width:84px;height:84px;border-radius:50%;background:#FDE7E9;color:var(--terracotta);
      display:flex;align-items:center;justify-content:center;margin:0 auto 14px;
      font-weight:900;font-size:15px;text-align:center;line-height:1.1;border:2px solid var(--gold);
    }

    /* ============ FINAL CTA ============ */
    .regrow-page .final{background:linear-gradient(180deg,var(--cream-soft),var(--cream));color:var(--ink);text-align:center}
    .regrow-page .final h2{color:var(--ink)}
    .regrow-page .final .lead{color:var(--muted)}
    .regrow-page .final .price-now{color:var(--terracotta)}
    .regrow-page .final .price-old{color:var(--muted)}

    .regrow-page footer{background:var(--black);color:rgba(255,255,255,.7);text-align:center;padding:26px 20px;font-size:13px}
    .regrow-page .foot-links{display:flex;flex-wrap:wrap;justify-content:center;gap:8px 20px;margin-bottom:14px}
    .regrow-page .foot-links a{color:#fff;text-decoration:none;font-weight:600;font-size:13.5px;opacity:.9}
    .regrow-page .foot-links a:hover{opacity:1;text-decoration:underline}

    /* ============ CTA דביק במובייל ============ */
    .regrow-page .sticky-cta{
      position:fixed;inset-inline:0;bottom:0;z-index:50;
      background:rgba(255,255,255,.97);border-top:1px solid var(--line);
      box-shadow:0 -6px 20px rgba(43,38,34,.10);
      padding:10px 16px;display:flex;align-items:center;gap:12px;
      backdrop-filter:blur(6px);
    }
    .regrow-page .sticky-cta .sp{display:flex;flex-direction:column;line-height:1.1}
    .regrow-page .sticky-cta .sp b{color:var(--terracotta);font-size:20px}
    .regrow-page .sticky-cta .sp s{color:var(--muted);font-size:13px}
    .regrow-page .sticky-cta .cta{margin:0;flex:1;max-width:none;padding:14px 18px;font-size:17px}

    /* ============ בס"ד + בר הכרזה עליון ============ */
    .regrow-page .besd{text-align:center;font-size:13px;color:var(--muted);padding:5px 0 0;letter-spacing:.02em}
    .regrow-page .announce{
      background:var(--cream-soft);color:var(--ink);text-align:center;font-size:13.5px;font-weight:700;
      padding:9px 16px;display:flex;flex-wrap:wrap;justify-content:center;gap:6px 18px;border-bottom:1px solid var(--line);
    }
    .regrow-page .announce span{display:inline-flex;align-items:center;gap:6px}
    .regrow-page .announce .hot{color:var(--terracotta)}

    /* ============ אמצעי תשלום ============ */
    .regrow-page .pay{display:flex;flex-wrap:wrap;justify-content:center;align-items:center;gap:8px;margin-top:16px}
    .regrow-page .pay .chip{
      background:#fff;border:1px solid var(--line);border-radius:8px;padding:5px 10px;
      font-size:12px;font-weight:700;color:var(--muted);box-shadow:0 1px 3px rgba(0,0,0,.04);
    }
    .regrow-page .pay .lbl{width:100%;text-align:center;color:var(--muted);font-size:12px;margin-bottom:2px}

    /* ============ סליידר לפני/אחרי ============ */
    .regrow-page .ba-slider{
      position:relative;max-width:520px;margin:26px auto 8px;border-radius:var(--radius);
      overflow:hidden;box-shadow:var(--shadow-lg);aspect-ratio:4/5;background:#fff;
      --pos:50;user-select:none;touch-action:none;
    }
    .regrow-page .ba-slider .layer{position:absolute;inset:0}
    .regrow-page .ba-slider .layer .ph{height:100%;min-height:0;border-radius:0}
    .regrow-page .ba-slider .before{clip-path:inset(0 calc((100 - var(--pos)) * 1%) 0 0)}
    .regrow-page .ba-slider .tag{
      position:absolute;top:12px;background:rgba(43,38,34,.78);color:#fff;
      font-size:12px;font-weight:700;padding:5px 12px;border-radius:999px;z-index:4;
    }
    .regrow-page .ba-slider .tag.b{left:12px}
    .regrow-page .ba-slider .tag.a{right:12px;background:var(--terracotta)}
    .regrow-page .ba-slider .divider{
      position:absolute;top:0;bottom:0;left:calc(var(--pos)*1%);width:3px;
      background:#fff;transform:translateX(-50%);z-index:3;box-shadow:0 0 0 1px rgba(0,0,0,.06);
    }
    .regrow-page .ba-slider .knob{
      position:absolute;top:50%;left:calc(var(--pos)*1%);transform:translate(-50%,-50%);
      width:42px;height:42px;border-radius:50%;background:#fff;z-index:3;
      display:flex;align-items:center;justify-content:center;color:var(--terracotta);
      font-weight:900;box-shadow:var(--shadow);pointer-events:none;
    }
    .regrow-page .ba-slider input[type=range]{
      position:absolute;inset:0;width:100%;height:100%;margin:0;opacity:0;cursor:ew-resize;z-index:5;
    }
    .regrow-page .ba-extra{display:grid;grid-template-columns:1fr;gap:14px;margin:18px auto 0;max-width:540px}
    .regrow-page .ba-split{border-radius:var(--radius-sm);overflow:hidden;box-shadow:var(--shadow);background:#fff}
    .regrow-page .ba-split .pair{display:grid;grid-template-columns:1fr 1fr}
    .regrow-page .ba-split .pair .ph{min-height:150px;border-radius:0}
    .regrow-page .ba-split .pair .ph.before-mini{border-inline-end:2px solid #fff}

    /* ============ מוצרים משלימים ============ */
    .regrow-page .addons{background:var(--cream)}
    .regrow-page .addon-grid{display:grid;grid-template-columns:1fr;gap:14px;margin-top:24px}
    .regrow-page .addon{
