    <div class="scm-cform" hidden>
      <h4>יש שאלה? נשמח לעזור</h4>
      <p>כתבו לנו והצוות יחזור אליכם במייל.</p>
      <input type="text" data-cname placeholder="שם" aria-label="שם">
      <input type="email" data-cemail placeholder="מייל לחזרה" aria-label="מייל לחזרה">
