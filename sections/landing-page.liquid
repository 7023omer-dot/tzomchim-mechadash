{%- comment -%}
  צומחים מחדש — דף נחיתה (עיצוב מאושר, RTL מלא)
  פלטה קרם/אדום/כהה · פונטים Frank Ruhl Libre + Heebo · 14 סקשנים · אנימציות.
  הכל מתוחם תחת .scm-page כדי לא לדלוף לשאר הת'מה.
{%- endcomment -%}

{%- liquid
  assign main_p = product
  if section.settings.main_product != blank
    assign main_p = section.settings.main_product
  endif
  assign cse = section.settings.addon_serum
  assign csh = section.settings.addon_shampoo
  assign vsrc = section.settings.video_asset | default: 'tz-video.mp4'
  if section.settings.hero_image != blank
    assign hero_img = section.settings.hero_image | image_url: width: 900
  elsif main_p != blank and main_p.featured_image
    assign hero_img = main_p.featured_image | image_url: width: 900
  else
    assign hero_img = 'tz-comb.webp' | asset_url
  endif
-%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Frank+Ruhl+Libre:wght@500;700;900&family=Heebo:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

<style>
  .scm-page{
    --accent:#D6392B; --accent-light:#FF5A3C; --accent-card:#FF8B72;
    --cream:#FAF5EE; --dark:#15110F; --dark2:#1C1714; --card-dark:#23201D; --footer:#0F0C0B;
    --light:#F4ECE1; --g1:#C9BEB2; --g2:#A99D90; --g3:#8A7E72; --gl1:#6B5F57; --gl2:#3A332E;
    --gold:#E8A33D; --green:#2E7D5B; --green2:#6BCB8E;
    --serif:'Frank Ruhl Libre',Georgia,serif; --sans:'Heebo',system-ui,Arial,sans-serif;
    direction:rtl; text-align:right; background:var(--cream); color:#1C1714;
    font-family:var(--sans); line-height:1.55; overflow-x:hidden;
  }
  .scm-page *{box-sizing:border-box;margin:0;padding:0}
  .scm-page img{max-width:100%;display:block}
  .scm-page h1,.scm-page h2,.scm-page h3,.scm-page .num,.scm-page .big-price{font-family:var(--serif);letter-spacing:-.4px}
  .scm-page .wrap{max-width:1180px;margin:0 auto;padding:0 clamp(18px,5vw,40px)}
  .scm-page .wrap.w1080{max-width:1080px}.scm-page .wrap.w980{max-width:980px}
  .scm-page .wrap.w920{max-width:920px}.scm-page .wrap.w820{max-width:820px}.scm-page .wrap.w720{max-width:720px}
  .scm-page section{padding:clamp(56px,7vw,96px) 0}
  .scm-page .eyebrow{display:inline-block;font-size:14px;font-weight:700;letter-spacing:2px;color:var(--accent);margin-bottom:14px}
  .scm-page .on-dark .eyebrow,.scm-page .dark .eyebrow{color:var(--accent-light)}
  .scm-page h2{font-size:clamp(28px,4vw,46px);font-weight:900;line-height:1.12;margin-bottom:14px}
  .scm-page .sec-head{text-align:center;margin-bottom:clamp(30px,4vw,52px)}
  .scm-page .sec-head p{color:var(--gl1);font-size:17px;max-width:640px;margin:0 auto}
  .scm-page .dark .sec-head p,.scm-page .dark2 .sec-head p{color:var(--g1)}

  /* כפתורים */
  .scm-page .cta{display:inline-flex;align-items:center;justify-content:center;gap:8px;background:var(--accent);color:#fff;
    font-family:var(--sans);font-weight:800;font-size:17px;padding:15px 30px;border:0;border-radius:999px;cursor:pointer;
    text-decoration:none;box-shadow:0 14px 34px rgba(214,57,43,.4);transition:transform .15s ease,filter .2s ease}
  .scm-page .cta:hover{transform:translateY(-2px);filter:brightness(1.06)}
  .scm-page .cta.sm{padding:11px 22px;font-size:15px;box-shadow:0 8px 20px rgba(214,57,43,.32)}
  .scm-page .cta.full{width:100%}
  .scm-page .cta.ghost{background:rgba(244,236,225,.1);border:1px solid rgba(244,236,225,.18);color:var(--light);box-shadow:none}
  .scm-page .cta.ghost:hover{background:rgba(244,236,225,.18)}

  /* מרקיזות */
  @keyframes scm-marquee{from{transform:translateX(0)}to{transform:translateX(-50%)}}
  @keyframes scm-glow{0%,100%{opacity:.5;transform:scale(1)}50%{opacity:.85;transform:scale(1.08)}}
  @keyframes scm-float{0%,100%{transform:translateY(0)}50%{transform:translateY(-14px)}}
  .scm-page .marq{overflow:hidden;white-space:nowrap;background:var(--dark);color:var(--light);padding:11px 0;font-size:14.5px;font-weight:500}
  .scm-page .marq .track{display:inline-flex;align-items:center;animation:scm-marquee 30s linear infinite}
  .scm-page .marq .track span{display:inline-flex;align-items:center;gap:46px;padding-inline-start:46px}
  .scm-page .marq .dia{color:var(--accent)}
  .scm-page .marq.promo{background:var(--accent);color:#fff;font-weight:700}
  .scm-page .marq.promo .track{animation-duration:24s}
  .scm-page .marq.promo .dia{color:#fff}

  /* ניווט */
  .scm-page .nav{position:sticky;top:0;z-index:60;background:rgba(250,245,238,.88);backdrop-filter:blur(12px);
    border-bottom:1px solid rgba(28,23,20,.07)}
  .scm-page .nav .in{display:flex;align-items:center;justify-content:space-between;gap:18px;height:64px}
  .scm-page .logo{display:inline-flex;align-items:center;gap:9px;text-decoration:none;color:#1C1714}
  .scm-page .logo .dot{width:30px;height:30px;border-radius:50%;background:var(--accent);color:#fff;display:flex;align-items:center;justify-content:center;font-family:var(--serif);font-weight:900;font-size:17px}
  .scm-page .logo b{font-family:var(--serif);font-weight:700;font-size:23px}
  .scm-page .nav-links{display:flex;gap:26px}
  .scm-page .nav-links a{color:#3A332E;text-decoration:none;font-size:15.5px;font-weight:500}
  .scm-page .nav-links a:hover{color:var(--accent)}

  /* HERO */
  .scm-page .hero{position:relative;background:var(--dark);color:var(--light);overflow:hidden}
  .scm-page .hero .glow{position:absolute;border-radius:50%;filter:blur(70px);z-index:0;pointer-events:none}
  .scm-page .hero .glow.a{width:420px;height:420px;background:rgba(214,57,43,.34);top:-90px;inset-inline-start:-80px;animation:scm-glow 6s ease-in-out infinite}
  .scm-page .hero .glow.b{width:360px;height:360px;background:rgba(255,90,60,.22);bottom:-100px;inset-inline-end:-60px}
  .scm-page .hero .in{position:relative;z-index:2;display:grid;grid-template-columns:1.05fr .95fr;gap:clamp(32px,5vw,72px);align-items:center}
  .scm-page .hero .pill{display:inline-flex;align-items:center;gap:9px;background:rgba(244,236,225,.08);border:1px solid rgba(244,236,225,.16);border-radius:999px;padding:8px 16px;font-size:13.5px;font-weight:600;color:var(--light);margin-bottom:22px}
  .scm-page .hero .pill .gd{width:9px;height:9px;border-radius:50%;background:var(--accent);box-shadow:0 0 10px var(--accent);animation:scm-glow 2s ease-in-out infinite}
  .scm-page .hero h1{font-size:clamp(38px,5.6vw,68px);font-weight:900;line-height:1.06;margin-bottom:20px}
  .scm-page .hero h1 em{display:block;color:var(--accent-light);font-style:italic}
  .scm-page .hero .lead{color:var(--g1);font-size:clamp(16px,2vw,20px);margin-bottom:26px;max-width:560px}
  .scm-page .hero .checks{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:30px}
  .scm-page .hero .checks li{list-style:none;display:flex;align-items:center;gap:10px;font-size:15.5px;color:var(--light)}
  .scm-page .hero .checks .ck{flex:0 0 auto;width:24px;height:24px;border-radius:50%;background:var(--accent);color:#fff;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:900}
  .scm-page .hero .cta-row{display:flex;align-items:center;gap:18px;flex-wrap:wrap}
  .scm-page .hero .rating{font-size:14px;color:var(--g1)}.scm-page .hero .rating .st{color:var(--gold)}
  .scm-page .hero .media{position:relative}
  .scm-page .hero .media .halo{position:absolute;inset:6% 8%;background:radial-gradient(circle,rgba(214,57,43,.4),transparent 70%);filter:blur(46px);z-index:0}
  .scm-page .hero .media img{position:relative;z-index:1;width:100%;border-radius:22px;box-shadow:0 40px 80px rgba(0,0,0,.5);animation:scm-float 6s ease-in-out infinite}

  /* וידאו */
  .scm-page .video-sec{background:var(--cream);text-align:center}
  .scm-page .video-sec .box{max-width:980px;margin:18px auto 0;border-radius:20px;overflow:hidden;box-shadow:0 24px 60px rgba(28,23,20,.18);background:#000}
  .scm-page .video-sec video{width:100%;aspect-ratio:16/9;object-fit:contain;display:block;background:#000}

  /* OFFER */
  .scm-page .offer{background:var(--dark2);color:var(--light)}
  .scm-page .offer .grid{display:grid;grid-template-columns:repeat(3,1fr);gap:22px;align-items:stretch;margin-top:8px}
  .scm-page .ocard{position:relative;display:flex;flex-direction:column;background:var(--card-dark);border:1px solid rgba(244,236,225,.08);border-radius:20px;padding:28px}
  .scm-page .ocard.best{background:linear-gradient(180deg,#2A1512,#1C1714);border:1.5px solid var(--accent);box-shadow:0 22px 50px rgba(214,57,43,.28)}
  .scm-page .ocard .tag{align-self:flex-start;font-size:12.5px;font-weight:800;letter-spacing:.5px;color:var(--accent-light);margin-bottom:12px}
  .scm-page .ocard.best .hot{position:absolute;top:-13px;inset-inline-start:50%;transform:translateX(50%);background:var(--accent);color:#fff;font-size:12.5px;font-weight:800;padding:6px 16px;border-radius:999px;white-space:nowrap}
  .scm-page .ocard .imgs{display:flex;align-items:center;justify-content:center;gap:8px;height:96px;margin-bottom:14px}
  .scm-page .ocard .imgs img{max-height:96px;width:auto;object-fit:contain}
  .scm-page .ocard .imgs .plus{color:var(--accent-light);font-weight:900;font-size:18px}
  .scm-page .ocard h3{font-size:21px;font-weight:700;margin-bottom:6px}
  .scm-page .ocard .desc{color:var(--g1);font-size:14px;min-height:42px;margin-bottom:14px}
  .scm-page .ocard .prow{display:flex;align-items:baseline;gap:10px;margin-bottom:4px}
  .scm-page .ocard .now{font-family:var(--serif);font-size:30px;font-weight:800}
  .scm-page .ocard .was{font-size:15px;color:var(--g3);text-decoration:line-through}
  .scm-page .ocard .save{color:var(--accent-light);font-size:13.5px;font-weight:700;margin-bottom:18px}
  .scm-page .ocard form{margin:0;margin-top:auto}
  .scm-page .ocard .cta{margin-top:auto}
  .scm-page .offer .pay{text-align:center;color:var(--g2);font-size:13.5px;margin-top:26px}

  /* PROBLEM */
  .scm-page .problem{background:var(--cream)}
  .scm-page .problem .rows{display:grid;gap:14px;margin-top:8px}
  .scm-page .problem .row{display:flex;align-items:flex-start;gap:14px;background:#fff;border:1px solid rgba(28,23,20,.07);border-radius:16px;padding:18px 20px;box-shadow:0 8px 24px rgba(28,23,20,.05)}
  .scm-page .problem .row .emo{font-size:24px;flex:0 0 auto}
  .scm-page .problem .row p{color:var(--gl2);font-size:16px}

  /* SOLUTION */
  .scm-page .solution{position:relative;background:var(--dark);color:var(--light);overflow:hidden}
  .scm-page .solution .glow{position:absolute;width:480px;height:480px;border-radius:50%;background:rgba(214,57,43,.2);filter:blur(80px);top:-120px;inset-inline-end:-100px;z-index:0}
  .scm-page .solution .in{position:relative;z-index:2}
  .scm-page .solution .cards{display:grid;grid-template-columns:repeat(3,1fr);gap:18px;margin-top:8px}
  .scm-page .solution .card{background:rgba(244,236,225,.05);border:1px solid rgba(244,236,225,.12);border-radius:18px;padding:26px}
  .scm-page .solution .card .ic{font-size:30px;margin-bottom:12px}
  .scm-page .solution .card h3{font-size:20px;font-weight:700;margin-bottom:8px}
  .scm-page .solution .card p{color:var(--g1);font-size:15px}
  .scm-page .solution .legal{color:var(--g3);font-size:13px;text-align:center;margin-top:26px;max-width:760px;margin-inline:auto}

  /* HOW */
  .scm-page .how{background:var(--cream);text-align:center}
  .scm-page .how .steps{display:grid;grid-template-columns:repeat(3,1fr);gap:26px;margin-top:8px}
  .scm-page .how .step .num{width:62px;height:62px;border-radius:50%;background:var(--accent);color:#fff;font-size:28px;font-weight:900;display:flex;align-items:center;justify-content:center;margin:0 auto 16px;box-shadow:0 12px 28px rgba(214,57,43,.34)}
  .scm-page .how .step h3{font-size:19px;font-weight:700;margin-bottom:6px}
  .scm-page .how .step p{color:var(--gl1);font-size:15px}

  /* BEFORE/AFTER */
  .scm-page .ba{background:var(--dark2);color:var(--light)}
  .scm-page .ba .grid{display:grid;grid-template-columns:1fr 1fr;gap:22px;margin-top:8px}
  .scm-page .ba .card{background:var(--card-dark);border-radius:18px;overflow:hidden;border:1px solid rgba(244,236,225,.08)}
  .scm-page .ba .pair{display:grid;grid-template-columns:1fr 1fr}
  .scm-page .ba .cell{position:relative}
  .scm-page .ba .cell img{width:100%;aspect-ratio:1/1;object-fit:cover;display:block}
  .scm-page .ba .cell.b{border-inline-end:2px solid var(--card-dark)}
  .scm-page .ba .lbl{position:absolute;top:10px;font-size:12px;font-weight:800;padding:4px 11px;border-radius:999px;z-index:2}
  .scm-page .ba .lbl.before{inset-inline-start:10px;background:rgba(0,0,0,.6);color:#fff}
  .scm-page .ba .lbl.after{inset-inline-end:10px;background:var(--accent);color:#fff}
  .scm-page .ba .cap{padding:12px 16px;text-align:center;font-weight:600;font-size:14.5px}
  .scm-page .ba .legal{color:var(--g3);font-size:13px;text-align:center;margin-top:20px}

  /* REVIEWS */
  .scm-page .reviews{background:var(--cream);text-align:center}
  .scm-page .reviews .top{display:flex;align-items:center;justify-content:center;gap:14px;margin-bottom:8px}
  .scm-page .reviews .top .n{font-family:var(--serif);font-size:54px;font-weight:900;color:#1C1714}
  .scm-page .reviews .top .st{color:var(--gold);font-size:24px;letter-spacing:2px}
  .scm-page .reviews .sub{color:var(--gl1);margin-bottom:30px}
  .scm-page .reviews .grid{display:grid;grid-template-columns:1fr 1fr;gap:18px;text-align:right}
  .scm-page .rcard{background:#fff;border:1px solid rgba(28,23,20,.07);border-radius:18px;padding:22px;box-shadow:0 8px 24px rgba(28,23,20,.05)}
  .scm-page .rcard .who{display:flex;align-items:center;gap:12px;margin-bottom:10px}
  .scm-page .rcard .av{width:44px;height:44px;border-radius:50%;background:var(--accent);color:#fff;font-weight:800;display:flex;align-items:center;justify-content:center}
  .scm-page .rcard .name{font-weight:700}.scm-page .rcard .st{color:var(--gold);font-size:14px}
  .scm-page .rcard p{color:var(--gl2);font-size:15px;margin-bottom:10px}
  .scm-page .rcard .vf{color:var(--green);font-size:12.5px;font-weight:700}

  /* COMPARISON */
  .scm-page .compare{background:var(--dark);color:var(--light)}
  .scm-page .compare .scroll{overflow-x:auto;margin-top:8px}
  .scm-page .compare table{width:100%;border-collapse:collapse;min-width:560px}
  .scm-page .compare th,.scm-page .compare td{padding:15px 14px;text-align:center;border-bottom:1px solid rgba(244,236,225,.1);font-size:15px}
  .scm-page .compare thead th{font-weight:800}
  .scm-page .compare thead th.us{color:var(--accent-light)}
  .scm-page .compare td:first-child,.scm-page .compare th:first-child{text-align:right;color:var(--g1)}
  .scm-page .compare td.us{color:var(--green2);font-weight:700}
  .scm-page .compare td.other{color:var(--g3)}

  /* FINAL */
  .scm-page .final{position:relative;background:var(--dark);color:var(--light);text-align:center;overflow:hidden;padding:clamp(64px,8vw,110px) 0}
  .scm-page .final .glow{position:absolute;width:520px;height:520px;border-radius:50%;background:rgba(214,57,43,.22);filter:blur(90px);top:50%;inset-inline-start:50%;transform:translate(50%,-50%);z-index:0}
  .scm-page .final .in{position:relative;z-index:2}
  .scm-page .final h2{margin-bottom:14px}
  .scm-page .final .lead{color:var(--g1);margin-bottom:20px}
  .scm-page .final .prow{display:flex;align-items:baseline;justify-content:center;gap:12px;margin-bottom:24px}
  .scm-page .final .now{font-family:var(--serif);font-size:46px;font-weight:900}
  .scm-page .final .was{font-size:20px;color:var(--g3);text-decoration:line-through}
  .scm-page .final .trust{margin-top:20px;color:var(--g1);font-size:14px;display:flex;gap:22px;justify-content:center;flex-wrap:wrap}

  /* FOOTER */
  .scm-page .ft{background:var(--footer);color:var(--g2)}
  .scm-page .ft .in{display:grid;grid-template-columns:1.4fr 1fr 1fr;gap:30px;padding:clamp(40px,5vw,64px) 0 0}
  .scm-page .ft .logo b{color:var(--light)}
  .scm-page .ft .brand p{margin:14px 0;font-size:14.5px;max-width:380px;line-height:1.7}
  .scm-page .ft .badges{display:flex;gap:10px;flex-wrap:wrap}
  .scm-page .ft .badge{background:rgba(244,236,225,.06);border:1px solid rgba(244,236,225,.12);border-radius:999px;padding:6px 14px;font-size:13px}
  .scm-page .ft h4{color:var(--light);font-size:15px;font-weight:700;margin-bottom:14px;font-family:var(--sans)}
  .scm-page .ft ul{list-style:none;display:grid;gap:9px}
  .scm-page .ft a{color:var(--g2);text-decoration:none;font-size:14.5px}
  .scm-page .ft a:hover{color:var(--light)}
  .scm-page .ft .copy{border-top:1px solid rgba(244,236,225,.08);margin-top:32px;padding:20px 0;text-align:center;font-size:13px;color:var(--g3)}

  /* רספונסיב */
  @media(max-width:768px){
    .scm-page .nav-links{display:none}
    .scm-page .hero .in{grid-template-columns:1fr;gap:32px}
    .scm-page .hero .media{order:-1}
    .scm-page .offer .grid,.scm-page .solution .cards,.scm-page .how .steps,.scm-page .ba .grid,.scm-page .reviews .grid{grid-template-columns:1fr}
    .scm-page .ft .in{grid-template-columns:1fr}
    .scm-page .ocard.best .hot{inset-inline-start:auto;inset-inline-end:16px;transform:none}
  }
</style>

<div class="scm-page" dir="rtl">

  {%- comment -%} ===== Schema.org JSON-LD ===== {%- endcomment -%}
  <script type="application/ld+json">
  {
    "@context":"https://schema.org",
    "@graph":[
      {"@type":"Organization","name":"צומחים מחדש","url":"{{ shop.url }}","logo":"https:{{ 'brand-logo.png' | asset_url }}"},
      {"@type":"Product",
        "name":"{% if main_p != blank %}{{ main_p.title | escape }}{% else %}מסרק אינפרא אדום לצמיחת שיער — צומחים מחדש{% endif %}",
        "image":"https:{{ hero_img }}",
        "description":"מכשיר 3-ב-1 לקרקפת: אור אדום בעוצמה נמוכה (LLLT), עיסוי קרקפת ואפליקטור סרום. 10 דקות ביום מהבית, לעידוד צמיחת שיער ובריאות הקרקפת.",
        "brand":{"@type":"Brand","name":"צומחים מחדש"},
        "offers":{"@type":"Offer","price":"{% if main_p != blank %}{{ main_p.price | money_without_currency | replace: ',', '' }}{% else %}148{% endif %}","priceCurrency":"ILS","availability":"https://schema.org/InStock","url":"{{ shop.url }}"}
      }
    ]
  }
  </script>

  <!-- 1. מרקיזת הכרזות -->
  <div class="marq" role="region" aria-label="הטבות">
    <div class="track">
      <span>🚚 משלוח חינם לכל הארץ<i class="dia">◆</i>🔒 תשלום מאובטח<i class="dia">◆</i>⭐ 1,300+ לקוחות מרוצים<i class="dia">◆</i></span>
      <span>🚚 משלוח חינם לכל הארץ<i class="dia">◆</i>🔒 תשלום מאובטח<i class="dia">◆</i>⭐ 1,300+ לקוחות מרוצים<i class="dia">◆</i></span>
    </div>
  </div>

  <!-- 2. ניווט -->
  <nav class="nav">
    <div class="wrap in">
      <a href="#" class="logo"><span class="dot">צ</span><b>צומחים מחדש</b></a>
      <div class="nav-links">
        <a href="#offer">הערכות</a>
        <a href="#how">איך זה עובד</a>
