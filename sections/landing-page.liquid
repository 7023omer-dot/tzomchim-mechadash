{%- comment -%}
  צומחים מחדש — דף נחיתה (סבב 5: פלטת אדום/לבן פרימיום, RTL מלא)
  לבן/שמנת דומיננטי · אדום מעודן אחד כאקסנט · טקסט כמעט-שחור · פונט Heebo.
  הכל מתוחם תחת .scm-page כדי לא לדלוף לשאר הת'מה.
{%- endcomment -%}

{%- liquid
  assign main_p = product
  if section.settings.main_product != blank
    assign main_p = section.settings.main_product
  endif
  assign cse = section.settings.addon_serum
  assign csh = section.settings.addon_shampoo
  assign vsrc = section.settings.video_asset | default: 'tz-video.mp4'
  if section.settings.hero_image != blank
    assign hero_img = section.settings.hero_image | image_url: width: 900
  elsif main_p != blank and main_p.featured_image
    assign hero_img = main_p.featured_image | image_url: width: 900
  else
    assign hero_img = 'tz-comb.webp' | asset_url
  endif
-%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Heebo:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">

<style>
  .scm-page{
    --red:#D11F2D; --red-dark:#B11825; --red-soft:#F7E6E7; --red-tint:#FCF1F1;
    --canvas:#FAFAF8; --white:#FFFFFF; --panel:#F3F1EB; --panel2:#EEEBE3;
    --ink:#1A1A1A; --ink2:#3A3A38; --muted:#6B6B66; --faint:#9A9A93;
    --line:#E7E4DD; --line2:#DEDAD1;
    --gold:#E0A93B; --green:#2E7D5B;
    --sans:'Heebo',system-ui,Arial,sans-serif;
    direction:rtl; text-align:right; background:var(--canvas); color:var(--ink);
    font-family:var(--sans); line-height:1.6; overflow-x:hidden;
  }
  .scm-page *{box-sizing:border-box;margin:0;padding:0}
  .scm-page img{max-width:100%;display:block}
  .scm-page h1,.scm-page h2,.scm-page h3{font-family:var(--sans);font-weight:800;letter-spacing:-.3px;color:var(--ink)}
  .scm-page .wrap{max-width:1180px;margin:0 auto;padding:0 clamp(18px,5vw,40px)}
  .scm-page .wrap.w1080{max-width:1080px}.scm-page .wrap.w980{max-width:980px}
  .scm-page .wrap.w920{max-width:920px}.scm-page .wrap.w820{max-width:820px}.scm-page .wrap.w720{max-width:720px}
  .scm-page section{padding:clamp(58px,7vw,98px) 0}
  .scm-page .eyebrow{display:inline-block;font-size:13px;font-weight:700;letter-spacing:2px;color:var(--red);margin-bottom:14px}
  .scm-page h2{font-size:clamp(27px,4vw,44px);font-weight:800;line-height:1.14;margin-bottom:14px}
  .scm-page .sec-head{text-align:center;margin-bottom:clamp(30px,4vw,52px)}
  .scm-page .sec-head p{color:var(--muted);font-size:17px;font-weight:400;max-width:640px;margin:0 auto}

  /* כפתורים */
  .scm-page .cta{display:inline-flex;align-items:center;justify-content:center;gap:8px;background:var(--red);color:#fff;
    font-family:var(--sans);font-weight:700;font-size:16.5px;padding:14px 30px;border:0;border-radius:10px;cursor:pointer;
    text-decoration:none;box-shadow:0 8px 22px rgba(209,31,45,.22);transition:transform .15s ease,background .2s ease,box-shadow .2s ease}
  .scm-page .cta:hover{transform:translateY(-1px);background:var(--red-dark);box-shadow:0 10px 26px rgba(209,31,45,.28)}
  .scm-page .cta.sm{padding:10px 20px;font-size:14.5px;box-shadow:0 6px 16px rgba(209,31,45,.18)}
  .scm-page .cta.full{width:100%}
  .scm-page .cta.ghost{background:#fff;border:1.5px solid var(--red);color:var(--red);box-shadow:none}
  .scm-page .cta.ghost:hover{background:var(--red-tint);color:var(--red-dark)}

  /* בס״ד — עדין, מימין למעלה */
  .scm-page .scm-bsd{background:var(--canvas);color:var(--faint);text-align:right;font-size:12px;font-weight:500;letter-spacing:1px;padding:5px clamp(18px,5vw,40px) 4px}

  /* הודעת אזהרה בכניסה */
  .scm-page .scm-warn{display:flex;align-items:center;justify-content:center;gap:10px;background:var(--red-soft);color:#7A1119;border-bottom:1px solid #EFCCCF;padding:9px 18px;font-size:13.5px;font-weight:600;text-align:center}
  .scm-page .scm-warn[hidden]{display:none}
  .scm-page .scm-warn svg{width:18px;height:18px;flex:0 0 auto;color:var(--red)}
  .scm-page .scm-warn .x{margin-inline-start:6px;background:none;border:0;color:#7A1119;cursor:pointer;font-size:19px;line-height:1;opacity:.65;padding:0 2px}
  .scm-page .scm-warn .x:hover{opacity:1}

  /* מרקיזות */
  @keyframes scm-marquee{from{transform:translateX(0)}to{transform:translateX(-50%)}}
  @keyframes scm-glow{0%,100%{opacity:.5;transform:scale(1)}50%{opacity:.85;transform:scale(1.08)}}
  @keyframes scm-float{0%,100%{transform:translateY(0)}50%{transform:translateY(-12px)}}
  .scm-page .marq{overflow:hidden;white-space:nowrap;background:var(--panel);color:var(--ink2);border-block:1px solid var(--line);padding:10px 0;font-size:14px;font-weight:600}
  .scm-page .marq .track{display:inline-flex;align-items:center;animation:scm-marquee 30s linear infinite}
  .scm-page .marq .track span{display:inline-flex;align-items:center;gap:46px;padding-inline-start:46px}
  .scm-page .marq .dia{color:var(--red)}
  .scm-page .marq.promo{background:var(--red);color:#fff;border-color:var(--red);font-weight:700}
  .scm-page .marq.promo .track{animation-duration:24s}
  .scm-page .marq.promo .dia{color:rgba(255,255,255,.8)}

  /* ניווט */
  .scm-page .nav{position:sticky;top:0;z-index:60;background:rgba(250,250,248,.9);backdrop-filter:blur(12px);
    border-bottom:1px solid var(--line)}
  .scm-page .nav .in{display:flex;align-items:center;justify-content:space-between;gap:18px;height:66px}
  .scm-page .brand-group{display:inline-flex;align-items:center;gap:14px}
  .scm-page .logo{display:inline-flex;align-items:center;gap:9px;text-decoration:none;color:var(--ink)}
  .scm-page .logo .dot{width:30px;height:30px;border-radius:8px;background:var(--red);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:900;font-size:17px}
  .scm-page .logo b{font-weight:800;font-size:21px;letter-spacing:-.4px}
  .scm-page .nav-links{display:flex;gap:24px}
  .scm-page .nav-links a{color:var(--ink2);text-decoration:none;font-size:15px;font-weight:600;cursor:pointer}
  .scm-page .nav-links a:hover{color:var(--red)}

  /* HERO */
  .scm-page .hero{position:relative;background:linear-gradient(180deg,#fff,var(--canvas));color:var(--ink);overflow:hidden}
  .scm-page .hero .glow{position:absolute;border-radius:50%;filter:blur(80px);z-index:0;pointer-events:none}
  .scm-page .hero .glow.a{width:380px;height:380px;background:rgba(209,31,45,.1);top:-90px;inset-inline-start:-70px;animation:scm-glow 7s ease-in-out infinite}
  .scm-page .hero .glow.b{width:320px;height:320px;background:rgba(209,31,45,.07);bottom:-90px;inset-inline-end:-50px}
  .scm-page .hero .in{position:relative;z-index:2;display:grid;grid-template-columns:1.05fr .95fr;gap:clamp(32px,5vw,72px);align-items:center}
  .scm-page .hero .pill{display:inline-flex;align-items:center;gap:9px;background:var(--white);border:1px solid var(--line2);border-radius:999px;padding:7px 15px;font-size:13px;font-weight:600;color:var(--ink2);margin-bottom:22px;box-shadow:0 4px 14px rgba(26,26,26,.04)}
  .scm-page .hero .pill .gd{width:8px;height:8px;border-radius:50%;background:var(--red);box-shadow:0 0 9px rgba(209,31,45,.7);animation:scm-glow 2s ease-in-out infinite}
  .scm-page .hero h1{font-size:clamp(31px,4.7vw,54px);font-weight:800;line-height:1.12;margin-bottom:20px;color:var(--ink)}
  .scm-page .hero h1 em{display:block;color:var(--red);font-style:normal}
  .scm-page .hero .lead{color:var(--muted);font-size:clamp(16px,2vw,19px);font-weight:400;margin-bottom:26px;max-width:560px}
  .scm-page .hero .checks{display:grid;grid-template-columns:1fr 1fr;gap:13px;margin-bottom:30px}
  .scm-page .hero .checks li{list-style:none;display:flex;align-items:center;gap:10px;font-size:15px;font-weight:500;color:var(--ink)}
  .scm-page .hero .checks .ck{flex:0 0 auto;width:22px;height:22px;border-radius:50%;background:var(--red);color:#fff;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:900}
  .scm-page .hero .cta-row{display:flex;align-items:center;gap:18px;flex-wrap:wrap}
  .scm-page .hero .rating{font-size:14px;color:var(--muted)}.scm-page .hero .rating .st{color:var(--gold)}
  .scm-page .hero .media{position:relative}
  .scm-page .hero .media .halo{position:absolute;inset:8% 10%;background:radial-gradient(circle,rgba(209,31,45,.16),transparent 70%);filter:blur(40px);z-index:0}
  .scm-page .hero .media img{position:relative;z-index:1;width:100%;border-radius:16px;box-shadow:0 30px 60px rgba(26,26,26,.16);animation:scm-float 6s ease-in-out infinite}

  /* וידאו + טקסט רגשי */
  .scm-page .video-sec{background:var(--white)}
  .scm-page .video-sec .vrow{display:grid;grid-template-columns:1fr 1fr;gap:clamp(28px,4vw,56px);align-items:center;margin-top:8px}
  .scm-page .video-sec .vtext p{color:var(--ink2);font-size:16.5px;line-height:1.85;margin-bottom:15px}
  .scm-page .video-sec .vtext p:first-child{font-size:19px;font-weight:700;color:var(--ink)}
  .scm-page .video-sec .vtext p:last-child{margin-bottom:0;color:var(--red);font-weight:700}
  .scm-page .video-sec .box{position:relative;width:100%;max-width:560px;margin:0 auto;border-radius:16px;overflow:hidden;box-shadow:0 20px 50px rgba(26,26,26,.18);background:#000}
  .scm-page .video-sec video{width:100%;aspect-ratio:16/9;object-fit:cover;display:block;background:#000}
  .scm-page .video-sec .vid-cta{position:absolute;bottom:16px;inset-inline-start:16px;z-index:4;display:none;align-items:center;gap:8px;background:var(--red);color:#fff;font-family:inherit;font-weight:800;font-size:16px;padding:11px 19px;border-radius:999px;box-shadow:0 8px 22px rgba(209,31,45,.5);text-decoration:none;animation:scm-pulse 1.4s ease-in-out infinite}
  .scm-page .video-sec .vid-cta.show{display:inline-flex}
  .scm-page .video-sec .vid-cta span{font-size:18px;line-height:1}
  @keyframes scm-pulse{0%,100%{transform:scale(1)}50%{transform:scale(1.06)}}

  /* BEFORE/AFTER */
  .scm-page .ba{background:var(--canvas)}
  .scm-page .ba .grid{display:grid;grid-template-columns:1fr 1fr;gap:22px;margin-top:8px}
  .scm-page .ba .card{background:var(--white);border-radius:14px;overflow:hidden;border:1px solid var(--line);box-shadow:0 8px 24px rgba(26,26,26,.05)}
  .scm-page .ba .pair{display:grid;grid-template-columns:1fr 1fr}
  .scm-page .ba .cell{position:relative}
  .scm-page .ba .cell img{width:100%;aspect-ratio:1/1;object-fit:cover;display:block}
  .scm-page .ba .cell.b{border-inline-end:2px solid var(--white)}
  .scm-page .ba .lbl{position:absolute;top:10px;font-size:12px;font-weight:800;padding:4px 11px;border-radius:999px;z-index:2}
  .scm-page .ba .lbl.before{inset-inline-start:10px;background:rgba(26,26,26,.62);color:#fff}
  .scm-page .ba .lbl.after{inset-inline-end:10px;background:var(--red);color:#fff}
  .scm-page .ba .cap{padding:13px 16px;text-align:center;font-weight:600;font-size:14.5px;color:var(--ink)}
  .scm-page .ba .legal{color:var(--faint);font-size:13px;text-align:center;margin-top:20px}

  /* OFFER */
  .scm-page .offer{background:var(--panel)}
  .scm-page .terms-gate{display:flex;justify-content:center;margin:0 0 22px}
  .scm-page .tcheck{display:inline-flex;align-items:flex-start;gap:9px;font-size:14px;color:var(--ink2);cursor:pointer;max-width:540px;line-height:1.5}
  .scm-page .tcheck input{margin-top:2px;width:17px;height:17px;accent-color:var(--red);flex:0 0 auto;cursor:pointer}
  .scm-page .tcheck a{color:var(--red);font-weight:700;text-decoration:underline}
  .scm-page .terms-gate.warn .tcheck{color:var(--red);font-weight:600}
  @keyframes scm-shake{0%,100%{transform:translateX(0)}20%,60%{transform:translateX(-5px)}40%,80%{transform:translateX(5px)}}
  .scm-page .terms-gate.warn{animation:scm-shake .42s}
  .scm-page .offer .grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:22px;align-items:stretch;margin-top:8px}
  .scm-page .ocard{position:relative;display:flex;flex-direction:column;background:var(--white);border:1px solid var(--line);border-radius:14px;padding:28px;box-shadow:0 8px 24px rgba(26,26,26,.05)}
  .scm-page .ocard.best{border:1.5px solid var(--red);box-shadow:0 20px 46px rgba(209,31,45,.16);transform:scale(1.05);z-index:2}
  .scm-page .ocard .tag{align-self:flex-start;font-size:12px;font-weight:800;letter-spacing:.5px;color:var(--red);margin-bottom:12px}
  .scm-page .ocard.best .hot{position:absolute;top:-13px;inset-inline-start:50%;transform:translateX(50%);background:var(--red);color:#fff;font-size:12px;font-weight:800;padding:6px 16px;border-radius:999px;white-space:nowrap;box-shadow:0 6px 16px rgba(209,31,45,.3)}
  .scm-page .ocard .imgs{display:flex;align-items:center;justify-content:center;gap:8px;height:96px;margin-bottom:14px}
  .scm-page .ocard .imgs img{max-height:96px;width:auto;object-fit:contain}
  .scm-page .ocard .imgs .plus{color:var(--red);font-weight:900;font-size:18px}
  .scm-page .ocard h3{font-size:20px;font-weight:800;margin-bottom:6px;color:var(--ink)}
  .scm-page .ocard .desc{color:var(--muted);font-size:14px;min-height:42px;margin-bottom:14px}
  .scm-page .ocard .prow{display:flex;align-items:baseline;gap:10px;margin-bottom:4px}
  .scm-page .ocard .now{font-size:29px;font-weight:800;color:var(--red)}
  .scm-page .ocard .was{font-size:15px;color:var(--faint);text-decoration:line-through}
  .scm-page .ocard .save{color:var(--green);font-size:13.5px;font-weight:700;margin-bottom:18px}
  .scm-page .ocard form{margin:0;margin-top:auto}
  .scm-page .ocard .cta{margin-top:auto}
  .scm-page .offer .pay{text-align:center;color:var(--muted);font-size:13.5px;margin-top:26px}

  /* HOW */
  .scm-page .how{background:var(--white);text-align:center}
  .scm-page .how .steps{display:grid;grid-template-columns:repeat(3,1fr);gap:26px;margin-top:8px}
  .scm-page .how .step .num{width:60px;height:60px;border-radius:50%;background:var(--red);color:#fff;font-size:26px;font-weight:900;display:flex;align-items:center;justify-content:center;margin:0 auto 16px;box-shadow:0 10px 24px rgba(209,31,45,.26)}
  .scm-page .how .step h3{font-size:19px;font-weight:800;margin-bottom:6px}
  .scm-page .how .step p{color:var(--muted);font-size:15px}

  /* REVIEWS */
  .scm-page .reviews{background:var(--canvas);text-align:center}
  .scm-page .reviews .top{display:flex;align-items:center;justify-content:center;gap:14px;margin-bottom:8px}
  .scm-page .reviews .top .n{font-size:52px;font-weight:900;color:var(--ink)}
  .scm-page .reviews .top .st{color:var(--gold);font-size:24px;letter-spacing:2px}
  .scm-page .reviews .sub{color:var(--muted);margin-bottom:30px}
  .scm-page .reviews .grid{display:grid;grid-template-columns:1fr 1fr;gap:18px;text-align:right}
  .scm-page .rcard{background:var(--white);border:1px solid var(--line);border-radius:14px;padding:22px;box-shadow:0 8px 24px rgba(26,26,26,.05)}
  .scm-page .rcard .who{display:flex;align-items:center;gap:12px;margin-bottom:10px}
  .scm-page .rcard .av{width:44px;height:44px;border-radius:50%;background:var(--red);color:#fff;font-weight:800;display:flex;align-items:center;justify-content:center}
  .scm-page .rcard .name{font-weight:700}.scm-page .rcard .st{color:var(--gold);font-size:14px}
  .scm-page .rcard p{color:var(--ink2);font-size:15px;margin-bottom:10px}
  .scm-page .rcard .vf{color:var(--green);font-size:12.5px;font-weight:700}

  /* FAQ */
  .scm-page .faq{background:var(--white)}
  .scm-page .faq .list{max-width:820px;margin:8px auto 0;display:grid;gap:10px}
  .scm-page .faq details{background:var(--canvas);border:1px solid var(--line);border-radius:12px;padding:0 18px}
  .scm-page .faq details[open]{border-color:var(--line2);box-shadow:0 6px 18px rgba(26,26,26,.05)}
  .scm-page .faq summary{list-style:none;cursor:pointer;display:flex;align-items:center;justify-content:space-between;gap:12px;padding:16px 0;font-weight:700;font-size:16px;color:var(--ink)}
  .scm-page .faq summary::-webkit-details-marker{display:none}
  .scm-page .faq summary .ic{flex:0 0 auto;width:22px;height:22px;border-radius:50%;border:1.5px solid var(--red);color:var(--red);display:flex;align-items:center;justify-content:center;font-weight:800;font-size:15px;transition:transform .2s ease}
  .scm-page .faq details[open] summary .ic{transform:rotate(45deg)}
  .scm-page .faq details p{color:var(--muted);font-size:15px;line-height:1.75;padding:0 0 18px}

  /* COMPARISON */
  .scm-page .compare{background:var(--canvas)}
  .scm-page .compare .scroll{overflow-x:auto;margin-top:8px}
  .scm-page .compare table{width:100%;border-collapse:collapse;min-width:560px;background:var(--white);border:1px solid var(--line);border-radius:14px;overflow:hidden}
  .scm-page .compare th,.scm-page .compare td{padding:15px 14px;text-align:center;border-bottom:1px solid var(--line);font-size:15px}
  .scm-page .compare thead th{font-weight:800;color:var(--ink);background:var(--panel)}
  .scm-page .compare thead th.us{color:var(--red)}
  .scm-page .compare td:first-child,.scm-page .compare th:first-child{text-align:right;color:var(--muted);font-weight:600}
  .scm-page .compare td.us{color:var(--green);font-weight:700}
  .scm-page .compare td.other{color:var(--faint)}

  /* FINAL */
  .scm-page .final{position:relative;background:var(--red-tint);text-align:center;overflow:hidden;padding:clamp(64px,8vw,108px) 0}
  .scm-page .final .glow{position:absolute;width:460px;height:460px;border-radius:50%;background:rgba(209,31,45,.08);filter:blur(90px);top:50%;inset-inline-start:50%;transform:translate(50%,-50%);z-index:0}
  .scm-page .final .in{position:relative;z-index:2}
  .scm-page .final h2{margin-bottom:14px}
  .scm-page .final .lead{color:var(--muted);margin-bottom:20px}
  .scm-page .final .prow{display:flex;align-items:baseline;justify-content:center;gap:12px;margin-bottom:24px}
  .scm-page .final .now{font-size:44px;font-weight:900;color:var(--red)}
  .scm-page .final .was{font-size:20px;color:var(--faint);text-decoration:line-through}
  .scm-page .final .trust{margin-top:20px;color:var(--muted);font-size:14px;display:flex;gap:22px;justify-content:center;flex-wrap:wrap}

  /* FOOTER */
  .scm-page .ft{background:var(--panel);color:var(--muted);border-top:1px solid var(--line)}
  .scm-page .ft .in{display:grid;grid-template-columns:1.4fr 1fr 1fr;gap:30px;padding:clamp(40px,5vw,64px) 0 0}
  .scm-page .ft .logo b{color:var(--ink)}
  .scm-page .ft .brand p{margin:14px 0;font-size:14.5px;max-width:380px;line-height:1.7}
  .scm-page .ft .badges{display:flex;gap:10px;flex-wrap:wrap}
  .scm-page .ft .badge{background:var(--white);border:1px solid var(--line);border-radius:999px;padding:6px 14px;font-size:13px;color:var(--ink2)}
  .scm-page .ft h4{color:var(--ink);font-size:15px;font-weight:700;margin-bottom:14px}
  .scm-page .ft ul{list-style:none;display:grid;gap:9px}
  .scm-page .ft a{color:var(--muted);text-decoration:none;font-size:14.5px}
  .scm-page .ft a:hover{color:var(--red)}
  .scm-page .ft .copy{border-top:1px solid var(--line);margin-top:32px;padding:20px 0;text-align:center;font-size:13px;color:var(--faint)}

  /* שורת דחיפות */
