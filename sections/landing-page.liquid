        </table>
      </div>
    </div>
  </section>

  <!-- ===================== OFFER / PRICING ===================== -->
  <section class="offer" id="offer">
    <div class="wrap center">
      <span class="eyebrow">ההצעה שלך</span>
      <h2>התחל/י את המסע לשיער מלא יותר היום</h2>
      <div class="price-card">
        <div class="offer-head">🔥 מבצע מיוחד — מחיר השקה</div>
        {%- if main_p -%}
        <div class="price-row">
          {%- if main_p.compare_at_price > main_p.price -%}<span class="price-old">{{ main_p.compare_at_price | money }}</span>{%- endif -%}
          <span class="price-now">{{ main_p.price | money }}</span>
        </div>
        {%- if main_p.compare_at_price > main_p.price -%}<div class="save">חוסך/ת {{ main_p.compare_at_price | minus: main_p.price | money }}</div>{%- endif -%}
        {%- else -%}
        <div class="price-row"><span class="price-old">₪199</span><span class="price-now">₪148</span></div>
        <div class="save">חיסכון 26% · 51 ₪</div>
        {%- endif -%}
        {%- if section.settings.timer_end != blank -%}
        <div class="rg-timer" data-rg-timer data-end="{{ section.settings.timer_end }}">
          <div class="rg-timer-label">⏳ מחיר ההשקה ננעל בעוד:</div>
          <div class="rg-timer-clock">
            <div class="rg-tbox"><span data-d>00</span><small>ימים</small></div><span class="rg-tsep">:</span>
            <div class="rg-tbox"><span data-h>00</span><small>שעות</small></div><span class="rg-tsep">:</span>
            <div class="rg-tbox"><span data-m>00</span><small>דקות</small></div><span class="rg-tsep">:</span>
            <div class="rg-tbox"><span data-s>00</span><small>שניות</small></div>
          </div>
        </div>
        {%- endif -%}
        <div class="urgency">{{ section.settings.urgency_text | default: '⏳ מלאי מוגבל — המבצע בתוקף עד גמר המלאי' }}</div>
        {%- if main_p -%}
        {%- form 'product', main_p -%}
          {%- unless main_p.has_only_default_variant -%}
            <select name="id" class="variant-select" aria-label="בחר/י אפשרות">
              {%- for v in main_p.variants -%}
                <option value="{{ v.id }}" {% unless v.available %}disabled{% endunless %}>{{ v.title }} — {{ v.price | money }}</option>
              {%- endfor -%}
            </select>
          {%- else -%}
            <input type="hidden" name="id" value="{{ main_p.selected_or_first_available_variant.id }}">
          {%- endunless -%}
          <button type="submit" name="add" class="cta" {% unless main_p.available %}disabled{% endunless %}>
            {%- if main_p.available -%}{{ section.settings.cta_text | default: 'הוסף/י לעגלה' }} — {{ main_p.price | money }}{%- else -%}אזל מהמלאי{%- endif -%}
            <span class="arrow">←</span>
          </button>
          {{ form | payment_button }}
        {%- endform -%}
        {%- else -%}
        <a href="/pages/catalog" class="cta">{{ section.settings.cta_text | default: 'הוסף/י לעגלה' }} <span class="arrow">←</span></a>
        {%- endif -%}
        <div class="trustbar">
          <span>🚚 משלוח חינם</span>
          <span>🔒 תשלום מאובטח</span>
        </div>
        <div class="guarantee-row">
          <span class="gr-seal">30<small>יום</small></span>
          <div class="gr-text"><b>אחריות 30 יום — כספך חזרה</b><span>לא מרוצה? מחזירים לך את הכסף, בלי שאלות.</span></div>
        </div>
        <div class="pay" aria-label="אמצעי תשלום">
          <span class="lbl">תשלום מאובטח באמצעות</span>
          <span class="chip">VISA</span>
          <span class="chip">Mastercard</span>
          <span class="chip">American Express</span>
          <span class="chip">bit</span>
          <span class="chip">PayPal</span>
          <span class="chip">Apple&nbsp;Pay</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== מוצרים משלימים + באנדל ===================== -->
  <section class="addons">
    <div class="wrap">
      <span class="eyebrow">מבצעי קומבו</span>
      <h2>המסרק לבד — או חוסכים עם קומבו</h2>
      <p class="lead">המסרק לבד נשאר ב-219 ₪. ההנחה נפתחת ברגע שמוסיפים מוצר — ככל שמשלבים יותר, חוסכים יותר.</p>

      <div class="combo-grid">
        <!-- מבצע 1 — מסרק + סרום -->
        <div class="bundle combo">
          <span class="badge">הקומבו המנצח 🔥</span>
          <div class="combo-imgs">
            <img src="{{ 'tz-comb.webp' | asset_url }}" alt="מסרק אינפרא אדום" loading="lazy">
            <span class="plus">+</span>
            <img src="{{ 'tz-ghkcu.webp' | asset_url }}" alt="סרום GHK-CU" loading="lazy">
          </div>
          <h3 style="font-size:20px;margin:8px 0 4px">מסרק + סרום</h3>
          <div class="items"><span>מסרק אינפרא אדום</span><span class="plus">+</span><span>סרום GHK-CU</span></div>
          <div class="price-row"><span class="price-old">₪258</span><span class="price-now">₪219</span></div>
          <div class="save">חוסך/ת 39 ₪ · 15%</div>
          {%- assign cse = section.settings.addon_serum -%}
          {%- assign csh = section.settings.addon_shampoo -%}
          {%- if main_p != blank and cse != blank -%}<button type="button" class="cta" data-combo-add="{{ main_p.selected_or_first_available_variant.id }},{{ cse.selected_or_first_available_variant.id }}" style="margin-top:14px">הוסיפו את הקומבו לסל — ₪219 <span class="arrow">←</span></button>{%- else -%}<a href="#offer" class="cta" style="margin-top:14px">הוסיפו את הקומבו לסל — ₪219 <span class="arrow">←</span></a>{%- endif -%}
        </div>

        <!-- מבצע 2 — מסרק + סרום + שמפו (הכי משתלם) -->
        <div class="bundle combo best">
          <span class="badge gold">הכי משתלם ⭐</span>
          <div class="combo-imgs">
            <img src="{{ 'tz-comb.webp' | asset_url }}" alt="מסרק אינפרא אדום" loading="lazy">
            <span class="plus">+</span>
            <img src="{{ 'tz-ghkcu.webp' | asset_url }}" alt="סרום GHK-CU" loading="lazy">
            <span class="plus">+</span>
            <img src="{{ 'tz-spartan.webp' | asset_url }}" alt="שמפו Spartan" loading="lazy">
          </div>
          <h3 style="font-size:20px;margin:8px 0 4px">הערכה המלאה — מסרק + סרום + שמפו</h3>
          <div class="items"><span>מסרק</span><span class="plus">+</span><span>סרום GHK-CU</span><span class="plus">+</span><span>שמפו Spartan</span></div>
          <div class="price-row"><span class="price-old">₪307</span><span class="price-now">₪249</span></div>
          <div class="save">חוסך/ת 58 ₪ · 19%</div>
          {%- if main_p != blank and cse != blank and csh != blank -%}<button type="button" class="cta" data-combo-add="{{ main_p.selected_or_first_available_variant.id }},{{ cse.selected_or_first_available_variant.id }},{{ csh.selected_or_first_available_variant.id }}" style="margin-top:14px">הוסיפו את הערכה לסל — ₪249 <span class="arrow">←</span></button>{%- else -%}<a href="#offer" class="cta" style="margin-top:14px">הוסיפו את הערכה לסל — ₪249 <span class="arrow">←</span></a>{%- endif -%}
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== FAQ ===================== -->
  <section class="faq">
    <div class="wrap">
      <span class="eyebrow">שאלות נפוצות</span>
      <h2>כל מה שרצית לשאול</h2>

      <details>
        <summary>תוך כמה זמן רואים תוצאות?</summary>
        <div class="ans">רוב המשתמשים מתחילים לשים לב לשינוי בתחושת המלאות תוך מספר שבועות של שימוש עקבי. התוצאות משתנות מאדם לאדם, ולכן אנחנו ממליצים על שימוש רציף לאורך זמן.</div>
      </details>
      <details>
        <summary>האם השימוש כואב?</summary>
        <div class="ans">לא. האור האדום בעוצמה נמוכה אינו מחמם ואינו כואב — רוב האנשים מתארים תחושה נעימה ורגועה.</div>
      </details>
      <details>
        <summary>מתאים גם לגברים וגם לנשים?</summary>
        <div class="ans">בהחלט. צומחים מחדש מתאים לכל סוגי השיער והקרקפת, לנשים עם דילול ולגברים עם נסיגת קו השיער כאחד.</div>
      </details>
      <details>
        <summary>מתאים גם לקרחת מתקדמת?</summary>
        <div class="ans">המכשיר עובד הכי טוב כשיש עדיין זקיקים פעילים — כלומר בדילול ובהקלשה. במצב של קרחת מתקדמת לאורך שנים התוצאות מוגבלות יותר, ומומלץ להיוועץ עם איש מקצוע לפני רכישה.</div>
      </details>
      <details>
        <summary>איך מנקים את המסרק?</summary>
        <div class="ans">פשוט מנגבים את שיני המסרק במטלית יבשה או לחה מעט. אין לשטוף תחת מים זורמים.</div>
      </details>
      <details>
        <summary>מה כוללת האחריות?</summary>
        <div class="ans">כל מסרק מגיע עם אחריות יצרן, וניתן להחזיר בהתאם למדיניות ההחזרות שלנו.</div>
      </details>
      <details>
        <summary>כמה זמן לוקח המשלוח?</summary>
        <div class="ans">המשלוח חינם ומגיע בדרך כלל תוך 2-4 ימי עסקים לכל הארץ.</div>
      </details>
      <details>
        <summary>מה מדיניות ההחזרות?</summary>
        <div class="ans">ניתן להחזיר את המוצר בהתאם למדיניות ההחזרות שלנו, כל עוד הוא במצב תקין.</div>
      </details>
      <details>
        <summary>האם זה בטוח לשימוש יומיומי?</summary>
        <div class="ans">כן. השימוש המומלץ הוא כ-3 פעמים בשבוע, 10 דקות בכל פעם. מומלץ להיוועץ ברופא אם יש לך מצב רפואי רלוונטי.</div>
      </details>
    </div>
  </section>

  <!-- ===================== FINAL CTA ===================== -->
  <section class="final">
    <div class="wrap center">
      <h2>השיער שלך מחכה — בוא/י נתחיל</h2>
      <p class="lead">מבצע לזמן מוגבל. הצטרף/י לאלפי לקוחות מרוצים.</p>
      <div class="price-row">
        {%- if main_p -%}
          {%- if main_p.compare_at_price > main_p.price -%}<span class="price-old">{{ main_p.compare_at_price | money }}</span>{%- endif -%}
          <span class="price-now">{{ main_p.price | money }}</span>
        {%- else -%}
          <span class="price-old">₪199</span><span class="price-now">₪148</span>
        {%- endif -%}
      </div>
      <a href="#offer" class="cta" style="margin-top:14px">אני רוצה שיער מלא יותר <span class="arrow">←</span></a>
    </div>
  </section>

  <footer>
    <nav class="foot-links" aria-label="קישורי תחתית">
      <a href="/pages/terms">תקנון ומדיניות החזרות</a>
      <a href="/pages/contact">צור קשר</a>
      <a href="/pages/faq">שאלות נפוצות</a>
    </nav>
    © <span id="yr"></span> צומחים מחדש <!-- BRAND -->. כל הזכויות שמורות. · המידע באתר אינו מהווה ייעוץ רפואי.
  </footer>

  <!-- ===================== CTA דביק במובייל ===================== -->
  <div class="sticky-cta" aria-label="קנייה מהירה">
    <div class="sp">
      <span style="font-size:13px;font-weight:700;color:#111">{{ main_p.title | default: 'מסרק צומחים מחדש' }}</span>
      {%- if main_p -%}
        <b>{{ main_p.price | money }}</b>
        {%- if main_p.compare_at_price > main_p.price -%}<s>{{ main_p.compare_at_price | money }}</s>{%- endif -%}
      {%- else -%}
        <b>₪148</b><s>₪199</s>
      {%- endif -%}
    </div>
    <a href="#offer" class="cta">הוסף/י לעגלה <span class="arrow">←</span></a>
  </div>

  <script>
    // שנה נוכחית ב-footer (ללא localStorage/sessionStorage)
    document.getElementById('yr').textContent = new Date().getFullYear();

    // סליידר לפני/אחרי — מעדכן את משתנה --pos לפי הגרירה
    document.querySelectorAll('.ba-slider').forEach(function(slider){
      var range = slider.querySelector('input[type=range]');
      if(!range) return;
      var update = function(){ slider.style.setProperty('--pos', range.value); };
      range.addEventListener('input', update);
      update();
    });

    // סרטון — מתנגן אוטומטית מושתק; כפתור 'הקש/י לקול' מפעיל סאונד
    document.querySelectorAll('[data-rg-video]').forEach(function(w){
      var v = w.querySelector('video');
      var u = w.querySelector('[data-rg-unmute]');
      if(!v) return;
      var p = v.play(); if(p && p.catch){ p.catch(function(){}); }
      if(u){
        u.addEventListener('click', function(){
          v.muted = !v.muted;
          u.classList.toggle('is-on', !v.muted);
          var t = u.querySelector('.utext'); if(t){ t.textContent = v.muted ? 'הקש/י לקול' : 'קול פעיל'; }
          if(!v.muted){ v.play(); }
        });
      }
    });

    // קומבו — הוספת רכיבים לסל; ה-Automatic Discount מחיל את מחיר הקומבו
    document.querySelectorAll('[data-combo-add]').forEach(function(btn){
      btn.addEventListener('click', function(){
        var items = btn.getAttribute('data-combo-add').split(',').map(function(x){
          return { id: parseInt(x, 10), quantity: 1 };
        }).filter(function(i){ return i.id; });
        if(!items.length) return;
        btn.setAttribute('aria-busy', 'true');
        fetch('{{ routes.cart_add_url }}.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ items: items })
        }).then(function(){ window.location.href = '{{ routes.cart_url }}'; })
          .catch(function(){ window.location.href = '{{ routes.cart_url }}'; });
      });
    });

    // טיימר ספירה לאחור — תאריך סיום קבוע מהגדרות הסקשן (נעלם בחן כשעובר)
    document.querySelectorAll('[data-rg-timer]').forEach(function(t){
      var end = new Date((t.getAttribute('data-end') || '').replace(' ', 'T')).getTime();
      if(isNaN(end)){ t.style.display = 'none'; return; }
      var dEl=t.querySelector('[data-d]'), hEl=t.querySelector('[data-h]'), mEl=t.querySelector('[data-m]'), sEl=t.querySelector('[data-s]');
      var pad=function(n){ return ('0'+n).slice(-2); };
      function tick(){
        var diff = end - Date.now();
        if(diff <= 0){ t.style.display='none'; clearInterval(iv); return; }
        dEl.textContent = Math.floor(diff/86400000);
        hEl.textContent = pad(Math.floor(diff%86400000/3600000));
        mEl.textContent = pad(Math.floor(diff%3600000/60000));
        sEl.textContent = pad(Math.floor(diff%60000/1000));
      }
      tick(); var iv=setInterval(tick,1000);
    });
  </script>
</div>
