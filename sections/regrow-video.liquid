{%- comment -%}
  צומחים מחדש — סקשן סרטון תדמית עצמאי
  משתמש בקובץ ה-MP4 התקין מ-assets (ברירת מחדל tz-video.mp4).
  נגן עם controls + קול בלחיצה, playsinline לנייד, RTL, רספונסיבי.
  ניתן להוסיף לכל עמוד/תבנית דרך עורך הת'מה.
{%- endcomment -%}

{%- assign vsrc = section.settings.video_asset | default: 'tz-video.mp4' -%}

{%- style -%}
  .rgv-{{ section.id }}{
    direction:rtl;text-align:center;
    background:{{ section.settings.bg_color }};
    padding:{{ section.settings.padding_top }}px 16px {{ section.settings.padding_bottom }}px;
  }
  .rgv-{{ section.id }} .rgv-head{
    font-size:clamp(22px,4vw,32px);font-weight:800;color:{{ section.settings.text_color }};
    margin:0 auto 6px;max-width:760px;
  }
  .rgv-{{ section.id }} .rgv-sub{
    font-size:clamp(14px,2.2vw,17px);color:{{ section.settings.text_color }};opacity:.8;
    margin:0 auto 18px;max-width:640px;
  }
  .rgv-{{ section.id }} .rgv-wrap{
    position:relative;margin:0 auto;max-width:{{ section.settings.max_width }}px;
    border-radius:18px;overflow:hidden;background:#000;
    box-shadow:0 16px 48px rgba(43,38,34,.18);line-height:0;
  }
  .rgv-{{ section.id }} .rgv-wrap video{
    width:100%;height:auto;display:block;background:#000;
  }
  .rgv-{{ section.id }} .rgv-play{
    position:absolute;inset:0;z-index:3;display:flex;align-items:center;justify-content:center;
    border:0;background:rgba(20,30,22,.28);cursor:pointer;transition:background .2s ease;
  }
  .rgv-{{ section.id }} .rgv-play:hover{background:rgba(20,30,22,.40)}
  .rgv-{{ section.id }} .rgv-play[hidden]{display:none}
  .rgv-{{ section.id }} .rgv-play .pcirc{
    width:78px;height:78px;border-radius:50%;background:rgba(255,255,255,.95);
    display:flex;align-items:center;justify-content:center;box-shadow:0 6px 22px rgba(0,0,0,.30);
  }
  .rgv-{{ section.id }} .rgv-play svg{width:32px;height:32px;margin-inline-start:5px;fill:{{ section.settings.text_color }}}
{%- endstyle -%}

<div class="rgv-{{ section.id }}" data-rgv>
  {%- if section.settings.heading != blank -%}<h2 class="rgv-head">{{ section.settings.heading | escape }}</h2>{%- endif -%}
  {%- if section.settings.subheading != blank -%}<p class="rgv-sub">{{ section.settings.subheading | escape }}</p>{%- endif -%}

  <div class="rgv-wrap">
    {%- if vsrc != blank -%}
      <video controls preload="metadata" playsinline{% if section.settings.poster != blank %} poster="{{ section.settings.poster | image_url: width: 900 }}"{% endif %}>
        <source src="{{ vsrc | asset_url }}" type="video/mp4">
        הדפדפן שלך אינו תומך בהצגת וידאו.
      </video>
    {%- elsif section.settings.video_file != blank -%}
      {{ section.settings.video_file | video_tag: controls: true, playsinline: true, muted: false, autoplay: false, loop: false, preload: 'metadata' }}
    {%- endif -%}
    <button type="button" class="rgv-play" aria-label="נגן/י את הסרטון">
      <span class="pcirc"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg></span>
    </button>
  </div>
</div>

<script>
(function(){
  var root=document.currentScript.previousElementSibling;
  if(!root)return;
  var v=root.querySelector('video'), b=root.querySelector('.rgv-play');
  if(!v||!b)return;
  b.addEventListener('click',function(){ v.play(); });
  v.addEventListener('play',function(){ b.hidden=true; });
  v.addEventListener('ended',function(){ b.hidden=false; });
})();
</script>

{% schema %}
{
  "name": "צומחים — סרטון תדמית",
  "tag": "section",
  "class": "section regrow-video",
  "settings": [
    { "type": "text", "id": "heading", "label": "כותרת", "default": "צפו בסרטון התדמית" },
    { "type": "text", "id": "subheading", "label": "כותרת משנה", "default": "" },
    { "type": "text", "id": "video_asset", "label": "שם קובץ הסרטון ב-assets", "default": "tz-video.mp4", "info": "הקובץ התקין כבר הועלה (tz-video.mp4). זו האופציה המומלצת." },
    { "type": "video", "id": "video_file", "label": "חלופה: סרטון מאוחסן-שופיפיי (אם לא משתמשים ב-assets)" },
    { "type": "image_picker", "id": "poster", "label": "תמונת תצוגה (poster) — אופציונלי" },
    { "type": "range", "id": "max_width", "min": 280, "max": 900, "step": 20, "unit": "px", "label": "רוחב מקסימלי לסרטון", "default": 380 },
    { "type": "header", "content": "צבעים וריווח" },
    { "type": "color", "id": "bg_color", "label": "רקע", "default": "#F3E8D8" },
    { "type": "color", "id": "text_color", "label": "טקסט", "default": "#2F4F35" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "ריווח עליון", "default": 40 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "ריווח תחתון", "default": 40 }
  ],
  "presets": [ { "name": "צומחים — סרטון תדמית" } ]
}
{% endschema %}
