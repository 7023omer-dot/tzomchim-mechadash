{%- comment -%}
  צומחים מחדש — סקשן סרטון תדמית עצמאי
  סרטון מתנגן אוטומטית מושתק (autoplay+muted+loop+playsinline) — מופיע ומתנגן בכל מקרה.
  כפתור 'הקש/י לקול' מפעיל סאונד. נפילה חיננית: אם אין סרטון — לא מוצג כלום.
  משתמש בקובץ ה-MP4 התקין מ-assets (ברירת מחדל tz-video.mp4). RTL, רספונסיבי.
{%- endcomment -%}

{%- assign vsrc = section.settings.video_asset | default: 'tz-video.mp4' -%}
{%- assign has_video = false -%}
{%- if vsrc != blank or section.settings.video_file != blank -%}{%- assign has_video = true -%}{%- endif -%}

{%- if has_video -%}
{%- style -%}
  .rgv-{{ section.id }}{
    direction:rtl;text-align:center;
    background:{{ section.settings.bg_color }};
    padding:{{ section.settings.padding_top }}px 16px {{ section.settings.padding_bottom }}px;
  }
  .rgv-{{ section.id }} .rgv-head{
    font-size:clamp(22px,4vw,32px);font-weight:800;color:{{ section.settings.text_color }};
    margin:0 auto 6px;max-width:760px;
  }
  .rgv-{{ section.id }} .rgv-sub{
    font-size:clamp(14px,2.2vw,17px);color:{{ section.settings.text_color }};opacity:.85;
    margin:0 auto 18px;max-width:640px;
  }
  .rgv-{{ section.id }} .rgv-wrap{
    position:relative;margin:0 auto;max-width:{{ section.settings.max_width }}px;
    border-radius:18px;overflow:hidden;background:#000;
    box-shadow:0 16px 48px rgba(43,38,34,.18);line-height:0;
  }
  .rgv-{{ section.id }} .rgv-wrap video{width:100%;height:auto;max-height:56vh;object-fit:contain;display:block;background:#000;margin:0 auto}
  .rgv-{{ section.id }} .rgv-btns{position:absolute;bottom:12px;inset-inline-start:12px;z-index:3;display:flex;gap:8px;align-items:center}
  .rgv-{{ section.id }} .rgv-unmute,.rgv-{{ section.id }} .rgv-fs{
    border:0;cursor:pointer;background:rgba(20,20,20,.66);color:#fff;
    font-family:inherit;font-weight:700;transition:background .2s ease;display:inline-flex;align-items:center;justify-content:center;
  }
  .rgv-{{ section.id }} .rgv-unmute{gap:6px;border-radius:999px;padding:8px 14px 8px 10px;font-size:13px}
  .rgv-{{ section.id }} .rgv-fs{border-radius:999px;width:38px;height:38px}
  .rgv-{{ section.id }} .rgv-unmute:hover,.rgv-{{ section.id }} .rgv-fs:hover{background:rgba(20,20,20,.88)}
  .rgv-{{ section.id }} .rgv-unmute.is-on{background:var(--rgv-red,#E8112D)}
  .rgv-{{ section.id }} .rgv-unmute svg,.rgv-{{ section.id }} .rgv-fs svg{width:18px;height:18px;fill:#fff}
{%- endstyle -%}

<div class="rgv-{{ section.id }}" data-rgv>
  {%- if section.settings.heading != blank -%}<h2 class="rgv-head">{{ section.settings.heading | escape }}</h2>{%- endif -%}
  {%- if section.settings.subheading != blank -%}<p class="rgv-sub">{{ section.settings.subheading | escape }}</p>{%- endif -%}

  <div class="rgv-wrap" style="max-width:{{ section.settings.max_width | default: 240 }}px;width:100%;margin-inline:auto">
    {%- if vsrc != blank -%}
      <video autoplay muted loop playsinline preload="auto" style="width:100%;height:auto;max-height:52vh;object-fit:contain;display:block"{% if section.settings.poster != blank %} poster="{{ section.settings.poster | image_url: width: 900 }}"{% endif %}>
        <source src="{{ vsrc | asset_url }}" type="video/mp4">
        הדפדפן שלך אינו תומך בהצגת וידאו.
      </video>
    {%- else -%}
      {{ section.settings.video_file | video_tag: autoplay: true, muted: true, loop: true, playsinline: true, controls: false }}
    {%- endif -%}
    <div class="rgv-btns">
      <button type="button" class="rgv-unmute" data-rgv-unmute aria-label="הפעל/י קול">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 10v4h4l5 5V5L7 10H3z"/><path d="M16.5 12a4.5 4.5 0 00-2.5-4.03v8.06A4.5 4.5 0 0016.5 12z"/></svg>
        <span class="utext">הקש/י לקול</span>
      </button>
      <button type="button" class="rgv-fs" data-rgv-fs aria-label="הגדל למסך מלא" title="מסך מלא">
        <svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 9V4h5M20 9V4h-5M4 15v5h5M20 15v5h-5"/></svg>
      </button>
    </div>
  </div>
</div>

<script>
(function(){
  var root=document.currentScript.previousElementSibling;
  if(!root)return;
  var v=root.querySelector('video'), u=root.querySelector('[data-rgv-unmute]'), fs=root.querySelector('[data-rgv-fs]');
  if(!v)return;
  var p=v.play(); if(p&&p.catch){p.catch(function(){});}
  if(u){
    u.addEventListener('click',function(){
      v.muted=!v.muted;
      u.classList.toggle('is-on',!v.muted);
      var t=u.querySelector('.utext'); if(t){t.textContent=v.muted?'הקש/י לקול':'קול פעיל';}
      if(!v.muted){v.play();}
    });
  }
  if(fs){
    fs.addEventListener('click',function(){
      var w=root.querySelector('.rgv-wrap');
      if(v.requestFullscreen){v.requestFullscreen();}
      else if(v.webkitEnterFullscreen){v.webkitEnterFullscreen();}      /* iPhone */
      else if(v.webkitRequestFullscreen){v.webkitRequestFullscreen();}
      else if(w&&w.requestFullscreen){w.requestFullscreen();}
      else if(w&&w.webkitRequestFullscreen){w.webkitRequestFullscreen();}
    });
  }
})();
</script>
{%- endif -%}

{% schema %}
{
  "name": "צומחים — סרטון תדמית",
  "tag": "section",
  "class": "section regrow-video",
  "settings": [
    { "type": "text", "id": "heading", "label": "כותרת", "default": "צפו בסרטון התדמית" },
    { "type": "text", "id": "subheading", "label": "כותרת משנה", "default": "" },
    { "type": "text", "id": "video_asset", "label": "שם קובץ הסרטון ב-assets", "default": "tz-video.mp4", "info": "הקובץ התקין כבר הועלה (tz-video.mp4). זו האופציה המומלצת." },
    { "type": "video", "id": "video_file", "label": "חלופה: סרטון מאוחסן-שופיפיי (אם לא משתמשים ב-assets)" },
    { "type": "image_picker", "id": "poster", "label": "תמונת תצוגה (poster) — אופציונלי" },
    { "type": "range", "id": "max_width", "min": 180, "max": 720, "step": 10, "unit": "px", "label": "רוחב מקסימלי לסרטון", "default": 260, "info": "הסרטון גם מוגבל בגובה (עד 56% מגובה המסך) כדי שייראה במלואו." },
    { "type": "header", "content": "צבעים וריווח" },
    { "type": "color", "id": "bg_color", "label": "רקע", "default": "#F3E8D8" },
    { "type": "color", "id": "text_color", "label": "טקסט", "default": "#2F4F35" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "ריווח עליון", "default": 40 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "ריווח תחתון", "default": 40 }
  ],
  "presets": [ { "name": "צומחים — סרטון תדמית" } ]
}
{% endschema %}
