{%- comment -%}
  צומחים מחדש — תקנון ומדיניות החזרות (עמוד מעוצב, RTL)
  התוכן מגיע מ-snippet משותף (regrow-terms-content) כדי שיוצג גם בעמוד /pages/terms
  ללא תלות בהגדרת תבנית בממשק שופיפיי. משובץ דרך תבנית page.terms.json.
{%- endcomment -%}

{%- render 'regrow-terms-content', padding_top: section.settings.padding_top, padding_bottom: section.settings.padding_bottom -%}

{% schema %}
{
  "name": "צומחים — תקנון",
  "tag": "section",
  "class": "section regrow-terms-section",
  "settings": [
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "ריווח עליון", "default": 44 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "ריווח תחתון", "default": 56 }
  ],
  "presets": [ { "name": "צומחים — תקנון" } ]
}
{% endschema %}
